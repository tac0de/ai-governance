{
  "version": "v0.6",
  "model": "casting-director-stateful",
  "roles": [
    {
      "id": "architect-owner",
      "name": "Architect Owner",
      "class": "governance",
      "mission": "Own macro direction, approve boundary changes, and resolve final tradeoffs.",
      "default_lane": "production",
      "leaseable": false,
      "home_department": "release-council",
      "allowed_departments": [
        "intake-routing",
        "release-council"
      ],
      "outputs": [
        "architecture decision",
        "approval gate decision",
        "scope freeze"
      ]
    },
    {
      "id": "service-builder",
      "name": "Service Builder",
      "class": "runtime",
      "mission": "Implement service-local code and operational changes inside the independent service repository.",
      "default_lane": "exploration",
      "leaseable": true,
      "home_department": "build-execution",
      "allowed_departments": [
        "build-execution"
      ],
      "outputs": [
        "runtime implementation",
        "integration change",
        "local release candidate"
      ]
    },
    {
      "id": "threejs-visual-specialist",
      "name": "Three.js Visual Specialist",
      "class": "specialist",
      "mission": "Own real-time scene composition, shader direction, camera, materials, and visual performance tradeoffs.",
      "default_lane": "exploration",
      "leaseable": true,
      "home_department": "specialist-studio",
      "allowed_departments": [
        "specialist-studio"
      ],
      "must_pair_with": [
        "service-builder",
        "visual-critic"
      ],
      "cannot_self_approve": true,
      "outputs": [
        "scene prototype",
        "rendering pass change",
        "visual tuning package"
      ]
    },
    {
      "id": "visual-critic",
      "name": "Visual Critic",
      "class": "review",
      "mission": "Score composition, detect failure patterns, and block childish or low-legibility regressions.",
      "default_lane": "exploration",
      "leaseable": true,
      "home_department": "review-gate",
      "allowed_departments": [
        "review-gate"
      ],
      "outputs": [
        "visual review packet",
        "failure classification",
        "acceptance gate signal"
      ]
    },
    {
      "id": "policy-ops",
      "name": "Policy Operations",
      "class": "governance",
      "mission": "Maintain validation logic, lane policy, and contract integrity.",
      "default_lane": "production",
      "leaseable": false,
      "home_department": "intake-routing",
      "allowed_departments": [
        "intake-routing",
        "release-council"
      ],
      "outputs": [
        "policy revision",
        "validator change",
        "contract update"
      ]
    },
    {
      "id": "release-review",
      "name": "Release Review",
      "class": "review",
      "mission": "Assess whether evidence and gates are coherent enough for production-facing release.",
      "default_lane": "production",
      "leaseable": true,
      "home_department": "review-gate",
      "allowed_departments": [
        "review-gate",
        "release-council"
      ],
      "outputs": [
        "release review decision",
        "risk note",
        "rollback recommendation"
      ]
    }
  ]
}
