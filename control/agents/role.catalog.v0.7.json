{
  "version": "v0.7",
  "model": "casting-director-stateful",
  "roles": [
    {
      "id": "architect-owner",
      "name": "Architect Owner",
      "class": "governance",
      "mission": "Own macro direction, approve boundary changes, and resolve final tradeoffs.",
      "default_lane": "production",
      "leaseable": false,
      "home_department": "release-council",
      "allowed_departments": [
        "intake-routing",
        "release-council"
      ],
      "outputs": [
        "architecture decision",
        "approval gate decision",
        "scope freeze"
      ]
    },
    {
      "id": "product-strategist",
      "name": "Product Strategist",
      "class": "product",
      "mission": "Turn requests into a clear service objective, milestone order, and scope boundary.",
      "default_lane": "exploration",
      "leaseable": true,
      "home_department": "intake-routing",
      "allowed_departments": [
        "intake-routing",
        "release-council"
      ],
      "outputs": [
        "product brief",
        "priority map",
        "scope constraint"
      ]
    },
    {
      "id": "service-builder",
      "name": "Service Builder",
      "class": "runtime",
      "mission": "Implement service-local code and operational changes inside the independent service repository.",
      "default_lane": "exploration",
      "leaseable": true,
      "home_department": "build-execution",
      "allowed_departments": [
        "build-execution"
      ],
      "outputs": [
        "runtime implementation",
        "integration change",
        "local release candidate"
      ]
    },
    {
      "id": "frontend-engineer",
      "name": "Frontend Engineer",
      "class": "runtime",
      "mission": "Implement user-facing UI, interaction flows, and client-side state inside the service repository.",
      "default_lane": "exploration",
      "leaseable": true,
      "home_department": "build-execution",
      "allowed_departments": [
        "build-execution"
      ],
      "outputs": [
        "ui implementation",
        "interaction patch",
        "frontend test update"
      ]
    },
    {
      "id": "backend-engineer",
      "name": "Backend Engineer",
      "class": "runtime",
      "mission": "Implement APIs, data flows, and server-side integration paths inside the service repository.",
      "default_lane": "exploration",
      "leaseable": true,
      "home_department": "build-execution",
      "allowed_departments": [
        "build-execution"
      ],
      "outputs": [
        "api change",
        "data integration patch",
        "backend reliability update"
      ]
    },
    {
      "id": "data-automation",
      "name": "Data Automation",
      "class": "runtime",
      "mission": "Own ingestion, transformation, automation flows, and operational data pipelines.",
      "default_lane": "exploration",
      "leaseable": true,
      "home_department": "build-execution",
      "allowed_departments": [
        "build-execution"
      ],
      "outputs": [
        "automation flow",
        "ingestion patch",
        "data pipeline change"
      ]
    },
    {
      "id": "design-lead",
      "name": "Design Lead",
      "class": "specialist",
      "mission": "Set visual direction, interaction quality, and experience constraints before or during implementation.",
      "default_lane": "exploration",
      "leaseable": true,
      "home_department": "specialist-studio",
      "allowed_departments": [
        "specialist-studio",
        "review-gate"
      ],
      "outputs": [
        "design direction",
        "experience constraint",
        "ui quality note"
      ]
    },
    {
      "id": "ux-specialist",
      "name": "UX Specialist",
      "class": "specialist",
      "mission": "Own interaction quality, usability flow, information hierarchy, and loop-breaking experience decisions for user-facing services.",
      "default_lane": "exploration",
      "leaseable": true,
      "home_department": "specialist-studio",
      "allowed_departments": [
        "specialist-studio",
        "review-gate"
      ],
      "must_pair_with": [
        "product-strategist",
        "frontend-engineer"
      ],
      "outputs": [
        "ux audit",
        "interaction flow revision",
        "usability remediation package"
      ]
    },
    {
      "id": "css-specialist",
      "name": "CSS Specialist",
      "class": "specialist",
      "mission": "Own layout systems, responsive behavior, design token application, and styling quality for front-end services.",
      "default_lane": "exploration",
      "leaseable": true,
      "home_department": "specialist-studio",
      "allowed_departments": [
        "specialist-studio",
        "build-execution"
      ],
      "must_pair_with": [
        "frontend-engineer",
        "design-lead"
      ],
      "outputs": [
        "styling system update",
        "responsive layout pass",
        "css remediation package"
      ]
    },
    {
      "id": "threejs-visual-specialist",
      "name": "Three.js Visual Specialist",
      "class": "specialist",
      "mission": "Own real-time scene composition, shader direction, camera, materials, and visual performance tradeoffs.",
      "default_lane": "exploration",
      "leaseable": true,
      "home_department": "specialist-studio",
      "allowed_departments": [
        "specialist-studio"
      ],
      "must_pair_with": [
        "service-builder",
        "visual-critic"
      ],
      "cannot_self_approve": true,
      "outputs": [
        "scene prototype",
        "rendering pass change",
        "visual tuning package"
      ]
    },
    {
      "id": "visual-critic",
      "name": "Visual Critic",
      "class": "review",
      "mission": "Score composition, detect failure patterns, and block low-legibility or low-quality visual regressions.",
      "default_lane": "exploration",
      "leaseable": true,
      "home_department": "review-gate",
      "allowed_departments": [
        "review-gate"
      ],
      "outputs": [
        "visual review packet",
        "failure classification",
        "acceptance gate signal"
      ]
    },
    {
      "id": "qa-reviewer",
      "name": "QA Reviewer",
      "class": "review",
      "mission": "Check regressions, confirm expected behavior, and block incomplete implementation paths.",
      "default_lane": "production",
      "leaseable": true,
      "home_department": "review-gate",
      "allowed_departments": [
        "review-gate"
      ],
      "outputs": [
        "qa report",
        "regression note",
        "test gate signal"
      ]
    },
    {
      "id": "security-review",
      "name": "Security Review",
      "class": "review",
      "mission": "Review secrets, permissions, data exposure, and boundary risks before release.",
      "default_lane": "production",
      "leaseable": true,
      "home_department": "review-gate",
      "allowed_departments": [
        "review-gate",
        "release-council"
      ],
      "outputs": [
        "security review packet",
        "risk escalation",
        "boundary exception note"
      ]
    },
    {
      "id": "devops-sre",
      "name": "DevOps SRE",
      "class": "operations",
      "mission": "Own runtime deployability, rollback readiness, observability, and operating safety.",
      "default_lane": "production",
      "leaseable": true,
      "home_department": "build-execution",
      "allowed_departments": [
        "build-execution",
        "release-council"
      ],
      "outputs": [
        "runbook update",
        "rollback plan",
        "operations readiness note"
      ]
    },
    {
      "id": "token-optimizer",
      "name": "Token Optimizer",
      "class": "operations",
      "mission": "Reduce model-token waste, tighten prompt surfaces, and improve inference cost efficiency without harming task quality.",
      "default_lane": "exploration",
      "leaseable": true,
      "home_department": "intake-routing",
      "allowed_departments": [
        "intake-routing",
        "build-execution",
        "review-gate"
      ],
      "outputs": [
        "prompt budget note",
        "cost-efficiency patch",
        "token usage review"
      ]
    },
    {
      "id": "policy-ops",
      "name": "Policy Operations",
      "class": "governance",
      "mission": "Maintain validation logic, lane policy, and contract integrity.",
      "default_lane": "production",
      "leaseable": false,
      "home_department": "intake-routing",
      "allowed_departments": [
        "intake-routing",
        "release-council"
      ],
      "outputs": [
        "policy revision",
        "validator change",
        "contract update"
      ]
    },
    {
      "id": "finance-ops",
      "name": "Finance Operations",
      "class": "business",
      "mission": "Model budget constraints, operating cost envelopes, and monetization-side guardrails for the service.",
      "default_lane": "production",
      "leaseable": true,
      "home_department": "intake-routing",
      "allowed_departments": [
        "intake-routing",
        "release-council"
      ],
      "outputs": [
        "budget guardrail",
        "cost scenario",
        "spend note"
      ]
    },
    {
      "id": "finance-controller",
      "name": "Finance Controller",
      "class": "review",
      "mission": "Review financial exposure, revenue impact, and cost compliance before major release decisions.",
      "default_lane": "production",
      "leaseable": true,
      "home_department": "review-gate",
      "allowed_departments": [
        "review-gate",
        "release-council"
      ],
      "outputs": [
        "financial review packet",
        "cost risk note",
        "approval constraint"
      ]
    },
    {
      "id": "growth-marketer",
      "name": "Growth Marketer",
      "class": "business",
      "mission": "Shape acquisition messaging, launch positioning, and measurable growth experiments for the service.",
      "default_lane": "exploration",
      "leaseable": true,
      "home_department": "intake-routing",
      "allowed_departments": [
        "intake-routing",
        "build-execution"
      ],
      "outputs": [
        "launch messaging brief",
        "growth experiment plan",
        "conversion hypothesis"
      ]
    },
    {
      "id": "crm-retention",
      "name": "CRM Retention",
      "class": "business",
      "mission": "Define lifecycle messaging, retention loops, and user reactivation paths for services with ongoing user engagement.",
      "default_lane": "exploration",
      "leaseable": true,
      "home_department": "build-execution",
      "allowed_departments": [
        "build-execution",
        "review-gate"
      ],
      "outputs": [
        "retention plan",
        "lifecycle messaging spec",
        "engagement experiment note"
      ]
    },
    {
      "id": "release-review",
      "name": "Release Review",
      "class": "review",
      "mission": "Assess whether evidence and gates are coherent enough for production-facing release.",
      "default_lane": "production",
      "leaseable": true,
      "home_department": "review-gate",
      "allowed_departments": [
        "review-gate",
        "release-council"
      ],
      "outputs": [
        "release review decision",
        "risk note",
        "rollback recommendation"
      ]
    }
  ]
}
