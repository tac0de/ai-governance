{
  "version": "v0.7",
  "model": "department-state-machine",
  "departments": [
    {
      "id": "intake-routing",
      "name": "Intake Routing",
      "purpose": "Classify requests, assign lane context, and decide whether temporary linking is justified.",
      "default_prompt_set": "governance-intake",
      "supports_roles": [
        "architect-owner",
        "product-strategist",
        "policy-ops",
        "finance-ops",
        "growth-marketer",
        "token-optimizer"
      ],
      "allowed_outputs": [
        "intake verdict",
        "lane assignment",
        "link request disposition"
      ]
    },
    {
      "id": "build-execution",
      "name": "Build Execution",
      "purpose": "Carry out service-local implementation and integration work inside the independent repository.",
      "default_prompt_set": "service-build",
      "supports_roles": [
        "service-builder",
        "frontend-engineer",
        "backend-engineer",
        "data-automation",
        "devops-sre",
        "growth-marketer",
        "crm-retention",
        "token-optimizer"
      ],
      "allowed_outputs": [
        "local implementation",
        "integration change",
        "rollback-ready patch"
      ]
    },
    {
      "id": "specialist-studio",
      "name": "Specialist Studio",
      "purpose": "Perform domain-specific high-skill work that should not be generalized into the central governance core.",
      "default_prompt_set": "specialist-pass",
      "supports_roles": [
        "design-lead",
        "threejs-visual-specialist"
      ],
      "allowed_outputs": [
        "specialist package",
        "prototype refinement",
        "tuning pass"
      ]
    },
    {
      "id": "review-gate",
      "name": "Review Gate",
      "purpose": "Evaluate outputs, catch regressions, and determine whether the work may progress toward release.",
      "default_prompt_set": "review-gate",
      "supports_roles": [
        "design-lead",
        "visual-critic",
        "qa-reviewer",
        "security-review",
        "finance-controller",
        "crm-retention",
        "token-optimizer",
        "release-review"
      ],
      "allowed_outputs": [
        "review packet",
        "failure classification",
        "release gate disposition"
      ]
    },
    {
      "id": "release-council",
      "name": "Release Council",
      "purpose": "Approve release posture, confirm rollback readiness, and authorize final production movement.",
      "default_prompt_set": "change-gate",
      "supports_roles": [
        "architect-owner",
        "product-strategist",
        "policy-ops",
        "devops-sre",
        "security-review",
        "finance-ops",
        "finance-controller",
        "release-review"
      ],
      "allowed_outputs": [
        "release approval",
        "rollback order",
        "promotion decision"
      ]
    }
  ]
}
