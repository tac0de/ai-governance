{
  "version": "v0.7",
  "model": "shell-entrypoints",
  "purpose": "Define the governed shell entrypoints that service-local operators use for plan, apply, gate, and trace workflows.",
  "commands": [
    {
      "command_id": "gov-plan",
      "entry_path": "governance/bin/gov-plan",
      "required_inputs": [
        "service_contract_ref",
        "policy_bundle_ref",
        "baseline_ref"
      ],
      "produces": [
        "plan_ref"
      ],
      "guardrails": [
        "Must not mutate runtime paths."
      ]
    },
    {
      "command_id": "gov-apply",
      "entry_path": "governance/bin/gov-apply",
      "required_inputs": [
        "plan_ref",
        "approval_receipt_ref",
        "rollback_ref"
      ],
      "produces": [
        "apply_receipt_ref"
      ],
      "guardrails": [
        "Must not run without approval receipt and rollback context."
      ]
    },
    {
      "command_id": "gov-gate",
      "entry_path": "governance/bin/gov-gate",
      "required_inputs": [
        "audit_bundle_ref",
        "release_review_ref",
        "trace_export_receipt"
      ],
      "produces": [
        "gate_verdict_ref"
      ],
      "guardrails": [
        "Must not issue release verdicts without audit bundle refs."
      ]
    },
    {
      "command_id": "gov-trace",
      "entry_path": "governance/bin/gov-trace",
      "required_inputs": [
        "trace_rules_ref",
        "record_type",
        "record_payload_ref"
      ],
      "produces": [
        "trace_append_receipt"
      ],
      "guardrails": [
        "Must preserve the DTP append-only contract."
      ]
    }
  ]
}
