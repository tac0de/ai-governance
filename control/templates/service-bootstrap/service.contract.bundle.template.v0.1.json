{
  "version": "v0.1",
  "service_id": "example-service",
  "summary": "Bootstrap-generated governance contract for an independent service repository.",
  "purpose": "Define the minimum portable governance kit that can operate without ai-governance at runtime.",
  "owner_role": "architect-owner",
  "governance_scope": {
    "execution_path": "service-local",
    "approval_boundary": [
      "medium for routine contract updates inside the local governance boundary",
      "high plus human gate for boundary expansion"
    ],
    "forbidden_actions": [
      "Runtime implementation in governance contracts",
      "Network-dependent verdict generation in deterministic paths"
    ],
    "scope_in": [
      "Service-local governance contracts",
      "Agent role definitions",
      "Planning and prompt strategies"
    ],
    "scope_out": [
      "Product runtime code",
      "External repository orchestration"
    ],
    "dependencies": [
      "governance/policy.profile.json",
      "governance/mcp.allowlist.json",
      "governance/slo.contract.v0.1.json",
      "governance/agent-roles/agent.roles.v0.1.json",
      "governance/agent-roles/agent.handoffs.v0.1.json"
    ],
    "primary_users": [
      "service owners",
      "governance maintainers"
    ],
    "decision_principles": [
      "Evidence-first",
      "Policy-first",
      "Portability-first"
    ]
  },
  "runbook": {
    "start_conditions": [
      "Bootstrap kit has been generated and reviewed locally."
    ],
    "steady_state": [
      "Keep governance artifacts portable and independent from ai-governance."
    ],
    "failure_response": [
      "Freeze local governance changes until the contract set is restored."
    ],
    "rollback_reference": [
      "Revert the latest contract-only change set."
    ],
    "access_revocation": [
      "Record local access revocation actions in the service repository."
    ]
  },
  "risk": {
    "tier": "medium",
    "failure_modes": [
      "Policy drift",
      "Missing evidence references"
    ],
    "mandatory_controls": [
      "Approval-tier enforcement",
      "Deterministic validation"
    ]
  },
  "data_contract": {
    "classification": "internal",
    "pii_allowed": false,
    "primary_artifacts": [
      "Service-local governance JSON contracts"
    ],
    "retention_policy": [
      "Keep only governance-relevant artifacts."
    ],
    "journal_export_policy": {
      "mode": "disabled",
      "target_service": null,
      "conditions": [
        "External journal export is optional and service-local."
      ]
    },
    "access_controls": [
      "Service owners and reviewers only."
    ]
  },
  "integrations": {
    "allowed_mcp_ids": [],
    "external_runtime_refs": [
      "Runtime stays outside governance contracts."
    ],
    "governance_interfaces": [
      "governance/bootstrap.manifest.v0.1.json",
      "governance/policy.profile.json"
    ],
    "extension_baseline": [
      "The bootstrap kit must remain portable to an independent service repository."
    ],
    "permissions_scope": [
      "Least privilege"
    ]
  },
  "slo_notes": {
    "common_kpi_set": "governance-core-v1",
    "critical_metrics": [
      {
        "id": "validation_reliability",
        "target": ">= 99%",
        "alert": "< 99%",
        "window": "7d",
        "notes": "Local governance validation pass ratio."
      }
    ],
    "error_budget": [
      "Freeze non-essential contract changes on budget burn."
    ]
  },
  "change_log": [
    {
      "release_line": "v0.3",
      "change": "Bootstrap-generated portable service governance contract.",
      "date_label": "release-line-v0.3"
    }
  ]
}
