{
  "version": "v0.1",
  "service_id": "example-service",
  "governance_source_refs": [
    "governance/service.contract.bundle.v0.1.json",
    "governance/policy.profile.json"
  ],
  "roles": [
    {
      "role_id": "intake-cell",
      "title": "Intake Cell",
      "governance_department_id": "service-review",
      "mission": "Translate requests into governed change packets.",
      "bounded_state_scope": [
        "Intake"
      ],
      "required_inputs": [
        "intent_ref",
        "policy_ref",
        "evidence_ref"
      ],
      "allowed_outputs": [
        "intake-brief"
      ],
      "output_contract_refs": [
        "governance/plan.strategy.v0.1.json"
      ],
      "allowed_actions": [
        "summarize change scope",
        "prepare deterministic handoff packets"
      ],
      "forbidden_actions": [
        "approve releases",
        "bypass evidence collection"
      ],
      "evidence_requirements": [
        "Every packet must include intent and evidence references."
      ],
      "policy_refs": [
        "governance/policy.profile.json"
      ],
      "handoff_targets": [
        "policy-safety-cell"
      ]
    },
    {
      "role_id": "policy-safety-cell",
      "title": "Policy Safety Cell",
      "governance_department_id": "policy-ops",
      "mission": "Check policy fit and escalation thresholds.",
      "bounded_state_scope": [
        "Review"
      ],
      "required_inputs": [
        "intent_ref",
        "policy_ref",
        "evidence_ref",
        "proposal_ref"
      ],
      "allowed_outputs": [
        "policy-verdict-note"
      ],
      "output_contract_refs": [
        "governance/plan.strategy.v0.1.json"
      ],
      "allowed_actions": [
        "check policy conflicts",
        "raise human gate when needed"
      ],
      "forbidden_actions": [
        "ignore approval tiers",
        "remove trace linkage"
      ],
      "evidence_requirements": [
        "Escalations must cite the governing policy."
      ],
      "policy_refs": [
        "governance/policy.profile.json"
      ],
      "handoff_targets": [
        "release-gate-cell"
      ]
    },
    {
      "role_id": "release-gate-cell",
      "title": "Release Gate Cell",
      "governance_department_id": "governance-council",
      "mission": "Issue the final hold or proceed verdict for a governance packet.",
      "bounded_state_scope": [
        "ReleaseGate"
      ],
      "required_inputs": [
        "intent_ref",
        "policy_ref",
        "evidence_ref",
        "verdict_ref"
      ],
      "allowed_outputs": [
        "release-gate-note"
      ],
      "output_contract_refs": [
        "governance/plan.strategy.v0.1.json"
      ],
      "allowed_actions": [
        "confirm required inputs",
        "hold high-tier changes pending human gate"
      ],
      "forbidden_actions": [
        "skip review",
        "mutate runtime configuration"
      ],
      "evidence_requirements": [
        "Final verdicts must preserve the evidence chain."
      ],
      "policy_refs": [
        "governance/policy.profile.json"
      ],
      "handoff_targets": []
    }
  ]
}
