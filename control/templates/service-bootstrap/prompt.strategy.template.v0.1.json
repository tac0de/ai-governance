{
  "version": "v0.1",
  "service_id": "example-service",
  "strategy_mode": "standard",
  "roles": [
    {
      "role_id": "intake-cell",
      "prompt_mode": "brief-normalization",
      "allowed_prompt_scopes": [
        "request-summary",
        "scope-clarification"
      ],
      "forbidden_prompt_patterns": [
        "runtime-code-generation",
        "policy-bypass"
      ],
      "required_refs": [
        "governance/policy.profile.json"
      ]
    },
    {
      "role_id": "policy-safety-cell",
      "prompt_mode": "policy-check",
      "allowed_prompt_scopes": [
        "compliance-review",
        "risk-escalation"
      ],
      "forbidden_prompt_patterns": [
        "unsupported-policy-edit",
        "evidence-free-approval"
      ],
      "required_refs": [
        "governance/policy.profile.json"
      ]
    },
    {
      "role_id": "release-gate-cell",
      "prompt_mode": "final-verdict",
      "allowed_prompt_scopes": [
        "release-hold",
        "release-proceed"
      ],
      "forbidden_prompt_patterns": [
        "silent-approval",
        "runtime-bypass"
      ],
      "required_refs": [
        "governance/policy.profile.json"
      ]
    }
  ],
  "global_guardrails": [
    "Prompts must preserve deterministic evidence references.",
    "Prompts must not embed runtime implementation steps."
  ]
}
