{
  "version": "v0.1",
  "mcp_id": "core-analytics-mcp",
  "summary": "Deterministic analytics contract for event aggregation and KPI summary support.",
  "purpose": "Aggregate UX events, compute governance-aligned KPI summaries, detect threshold-bounded anomalies, and propose deterministic learning actions.",
  "capability_contract": {
    "allowed_operations": [
      "aggregate_events",
      "compute_kpi_summary",
      "detect_anomaly",
      "propose_learning_actions"
    ],
    "forbidden_expansion": [
      "Runtime database ownership.",
      "Non-deterministic scoring logic."
    ],
    "required_approval_tier": "medium",
    "scope": [
      "Aggregate events for fixed UTC windows.",
      "Compute governance-aligned KPI summaries.",
      "Detect anomalies using policy-bounded thresholds.",
      "Propose deterministic learning actions from KPI deltas."
    ]
  },
  "security_boundary": {
    "allowed_inputs": [
      "Policy-validated arguments.",
      "Schema-checked event aggregates."
    ],
    "forbidden_inputs": [
      "Secret material.",
      "Unchecked free-form payloads."
    ],
    "non_goals": [
      "Runtime database ownership.",
      "Any non-deterministic scoring path."
    ],
    "controls": [
      "Inputs are policy-validated and schema-checked.",
      "No secret material is emitted in MCP outputs."
    ]
  },
  "evidence_contract": {
    "required_refs": [
      "intent_ref",
      "evidence_ref",
      "source_ref"
    ],
    "hash_policy": "Outputs must remain hash-referenced and replayable.",
    "trace_linkage": "Every output must remain trace-linkable through intent_ref, evidence_ref, and source_ref."
  },
  "runtime_contract": {
    "binding_ref": "control/mcps/core-analytics-mcp/versions/runtime.binding.v0.1.json",
    "runtime_owner_service": "thedivineparadox",
    "runtime_repo_path": "apps/mcp-runtime/src/runtime.ts",
    "invocation_surface": "POST /invoke (local HTTP sidecar)",
    "sdk_package": "@modelcontextprotocol/sdk",
    "validation_package": "zod",
    "tool_names": [
      "analytics.aggregate_events",
      "analytics.compute_kpi_summary",
      "analytics.detect_anomaly",
      "analytics.propose_learning_actions"
    ]
  },
  "change_log": [
    {
      "release_line": "v0.2",
      "change": "Collapsed analytics MCP Markdown docs into a single JSON contract bundle.",
      "date_label": "2026-02-27"
    }
  ]
}
