{
  "version": "v0.1",
  "service_id": "gongvue",
  "distribution_mode": "docker_image",
  "core_visibility": "opaque",
  "extension_baseline": [
    "plugin",
    "sidecar"
  ],
  "plugin_mount_path": "/opt/gongvue/plugins",
  "plugin_entrypoint_contract": {
    "entry_file": "custom_action.js",
    "required_input_fields": [
      "event_id",
      "event_type",
      "trace_ref",
      "payload_ref"
    ],
    "required_output_fields": [
      "actions",
      "policy_verdict"
    ],
    "policy_verdict_enum": [
      "allow",
      "deny"
    ]
  },
  "sidecar_webhook_contract": {
    "endpoint_env": "GONGVUE_SIDECAR_WEBHOOK_URL",
    "auth_mode": "hmac_sha256_signature",
    "required_event_fields": [
      "event_id",
      "event_type",
      "trace_ref",
      "payload_ref",
      "idempotency_key"
    ],
    "timeout_ms": 2000,
    "retry": {
      "max_attempts": 3,
      "backoff_ms": 500
    }
  },
  "security_controls": {
    "plugin_timeout_ms": 1500,
    "plugin_cpu_limit": "0.5",
    "plugin_memory_limit_mb": 256,
    "plugin_fs_write_scope": [
      "/tmp/plugin-sandbox"
    ],
    "denylist": [
      "core_engine_import",
      "host_network_access",
      "raw_secret_read"
    ]
  },
  "approval_tier": "high",
  "human_gate_required": true
}
