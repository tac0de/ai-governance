{
  "version": "v0.1",
  "request_id": "mcp.req.tdp.vision.ux_gate.20260223",
  "service_id": "thedivineparadox",
  "title": "MCP request for Vision Critique UX quality gate",
  "requested_at": "2026-02-23T02:20:00Z",
  "approval_tier": "high",
  "human_gate_required": true,
  "owner": "architect-owner",
  "objective": "Establish a deterministic UI quality gate by combining browser screenshot capture and structured visual critique before release promotion.",
  "required_capabilities": [
    "vision.image_critique.evaluate",
    "vision.layout_readability.score",
    "vision.contrast_accessibility.check",
    "vision.brand_consistency.check",
    "artifact.report.write",
    "github.actions.check_run_create"
  ],
  "constraints": [
    "No business logic mutation from visual critique output.",
    "Critique output must be JSON-only and schema-validated.",
    "Every critique run must reference commit SHA, route URL, viewport, and screenshot hash.",
    "Release gate uses fixed rubric weights and fixed threshold per environment.",
    "Production promotion still requires explicit architect sign-off."
  ],
  "io_contract": {
    "input_schema": {
      "type": "object",
      "required": [
        "service_id",
        "commit_sha",
        "env",
        "route",
        "viewport",
        "screenshot_sha256"
      ],
      "properties": {
        "service_id": {
          "type": "string",
          "const": "thedivineparadox"
        },
        "commit_sha": {
          "type": "string",
          "minLength": 7
        },
        "env": {
          "type": "string",
          "enum": [
            "staging",
            "production"
          ]
        },
        "route": {
          "type": "string"
        },
        "viewport": {
          "type": "object",
          "required": [
            "width",
            "height"
          ],
          "properties": {
            "width": {
              "type": "integer"
            },
            "height": {
              "type": "integer"
            }
          },
          "additionalProperties": false
        },
        "screenshot_sha256": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        }
      },
      "additionalProperties": false
    },
    "output_schema": {
      "type": "object",
      "required": [
        "overall_score",
        "verdict",
        "issues",
        "action_items",
        "rubric_breakdown"
      ],
      "properties": {
        "overall_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "verdict": {
          "type": "string",
          "enum": [
            "pass",
            "fail"
          ]
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "severity",
              "category",
              "selector_or_region",
              "summary",
              "fix_hint"
            ],
            "properties": {
              "severity": {
                "type": "string",
                "enum": [
                  "critical",
                  "major",
                  "minor"
                ]
              },
              "category": {
                "type": "string",
                "enum": [
                  "layout",
                  "typography",
                  "contrast",
                  "hierarchy",
                  "consistency"
                ]
              },
              "selector_or_region": {
                "type": "string"
              },
              "summary": {
                "type": "string"
              },
              "fix_hint": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "action_items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rubric_breakdown": {
          "type": "object",
          "required": [
            "visual_clarity",
            "readability",
            "consistency",
            "a11y_contrast"
          ],
          "properties": {
            "visual_clarity": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "readability": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "consistency": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "a11y_contrast": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "evidence_refs": [
    {
      "path": "reports/governance/mcp-request-tdp-ops-stabilization-20260223.json",
      "sha256": "b7daa1767c1445efca022a71619d1ec56f09957c1bbceea6300a7bdcce3bc2ef"
    }
  ],
  "status": "requested"
}
