{
  "version": "v0.1",
  "service_id": "plotnodes",
  "governance_source_refs": [
    "services/plotnodes/contract.bundle.v0.1.json",
    "services/plotnodes/policy.profile.json"
  ],
  "roles": [
    {
      "role_id": "intake-cell",
      "title": "Intake Cell",
      "governance_department_id": "service-review",
      "mission": "Translate Plotnodes changes into deterministic governance packets before any runtime work proceeds.",
      "bounded_state_scope": [
        "Intake"
      ],
      "required_inputs": [
        "intent_ref",
        "policy_ref",
        "evidence_ref"
      ],
      "allowed_outputs": [
        "intake-brief"
      ],
      "output_contract_refs": [
        "schemas/service_plan_strategy.schema.json"
      ],
      "allowed_actions": [
        "summarize scope",
        "prepare handoff",
        "flag high-tier boundary claims"
      ],
      "forbidden_actions": [
        "approve release",
        "remove evidence refs",
        "mutate runtime"
      ],
      "evidence_requirements": [
        "Every intake packet must name its intent, policy, and evidence references."
      ],
      "policy_refs": [
        "services/plotnodes/policy.profile.json"
      ],
      "handoff_targets": [
        "policy-safety-cell"
      ]
    },
    {
      "role_id": "policy-safety-cell",
      "title": "Policy Safety Cell",
      "governance_department_id": "policy-ops",
      "mission": "Apply the no-training, secret-hygiene, and trace-integrity policy boundary before release gating.",
      "bounded_state_scope": [
        "Review"
      ],
      "required_inputs": [
        "intent_ref",
        "policy_ref",
        "evidence_ref",
        "proposal_ref"
      ],
      "allowed_outputs": [
        "policy-verdict-note"
      ],
      "output_contract_refs": [
        "schemas/service_plan_strategy.schema.json"
      ],
      "allowed_actions": [
        "check policy fit",
        "flag escalation",
        "record boundary exceptions"
      ],
      "forbidden_actions": [
        "silence escalation",
        "bypass review",
        "approve new permissions without a human gate"
      ],
      "evidence_requirements": [
        "Review notes must preserve the evidence chain and cite the governing policy."
      ],
      "policy_refs": [
        "services/plotnodes/policy.profile.json"
      ],
      "handoff_targets": [
        "release-gate-cell"
      ]
    },
    {
      "role_id": "release-gate-cell",
      "title": "Release Gate Cell",
      "governance_department_id": "governance-council",
      "mission": "Issue a deterministic hold or proceed note for Plotnodes governance packets.",
      "bounded_state_scope": [
        "ReleaseGate"
      ],
      "required_inputs": [
        "intent_ref",
        "policy_ref",
        "evidence_ref",
        "verdict_ref"
      ],
      "allowed_outputs": [
        "release-gate-note"
      ],
      "output_contract_refs": [
        "schemas/service_plan_strategy.schema.json"
      ],
      "allowed_actions": [
        "issue final gate",
        "hold high-tier changes",
        "confirm approval completeness"
      ],
      "forbidden_actions": [
        "skip approval",
        "mutate runtime",
        "weaken trace linkage requirements"
      ],
      "evidence_requirements": [
        "Release decisions must preserve intent, policy, and evidence references."
      ],
      "policy_refs": [
        "services/plotnodes/policy.profile.json"
      ],
      "handoff_targets": []
    }
  ]
}
