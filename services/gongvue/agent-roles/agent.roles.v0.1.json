{
  "version": "v0.1",
  "service_id": "gongvue",
  "governance_source_refs": [
    "services/gongvue/contract.bundle.v0.1.json",
    "services/gongvue/policy.profile.json"
  ],
  "roles": [
    {
      "role_id": "intake-cell",
      "title": "Intake Cell",
      "governance_department_id": "service-review",
      "mission": "Normalize requests into a seed-ready governance packet.",
      "bounded_state_scope": [
        "Intake"
      ],
      "required_inputs": [
        "intent_ref",
        "policy_ref",
        "evidence_ref"
      ],
      "allowed_outputs": [
        "intake-brief"
      ],
      "output_contract_refs": [
        "schemas/service_plan_strategy.schema.json"
      ],
      "allowed_actions": [
        "summarize scope",
        "prepare handoff"
      ],
      "forbidden_actions": [
        "approve release",
        "remove evidence refs"
      ],
      "evidence_requirements": [
        "Every intake packet must name its intent and evidence refs."
      ],
      "policy_refs": [
        "services/gongvue/policy.profile.json"
      ],
      "handoff_targets": [
        "policy-safety-cell"
      ]
    },
    {
      "role_id": "policy-safety-cell",
      "title": "Policy Safety Cell",
      "governance_department_id": "policy-ops",
      "mission": "Apply the seed policy profile before release gating.",
      "bounded_state_scope": [
        "Review"
      ],
      "required_inputs": [
        "intent_ref",
        "policy_ref",
        "evidence_ref",
        "proposal_ref"
      ],
      "allowed_outputs": [
        "policy-verdict-note"
      ],
      "output_contract_refs": [
        "schemas/service_plan_strategy.schema.json"
      ],
      "allowed_actions": [
        "check policy fit",
        "flag escalation"
      ],
      "forbidden_actions": [
        "silence escalation",
        "bypass review"
      ],
      "evidence_requirements": [
        "Review notes must preserve the evidence chain."
      ],
      "policy_refs": [
        "services/gongvue/policy.profile.json"
      ],
      "handoff_targets": [
        "release-gate-cell"
      ]
    },
    {
      "role_id": "release-gate-cell",
      "title": "Release Gate Cell",
      "governance_department_id": "governance-council",
      "mission": "Issue a deterministic hold or proceed note.",
      "bounded_state_scope": [
        "ReleaseGate"
      ],
      "required_inputs": [
        "intent_ref",
        "policy_ref",
        "evidence_ref",
        "verdict_ref"
      ],
      "allowed_outputs": [
        "release-gate-note"
      ],
      "output_contract_refs": [
        "schemas/service_plan_strategy.schema.json"
      ],
      "allowed_actions": [
        "issue final gate",
        "hold high-tier changes"
      ],
      "forbidden_actions": [
        "skip approval",
        "mutate runtime"
      ],
      "evidence_requirements": [
        "Release decisions must keep evidence refs."
      ],
      "policy_refs": [
        "services/gongvue/policy.profile.json"
      ],
      "handoff_targets": []
    }
  ]
}
