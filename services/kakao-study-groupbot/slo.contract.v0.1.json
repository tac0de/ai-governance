{
  "version": "v0.1",
  "common_kpi_set": "governance-core-v1",
  "kpis": [
    {
      "id": "explainability_coverage",
      "enabled": true,
      "comparison": "gte",
      "target": 1.0,
      "alert_threshold": 1.0,
      "window": "release-candidate",
      "notes": "모든 변경은 intent/policy/evidence/trace 링크를 포함한다."
    },
    {
      "id": "validation_reliability",
      "enabled": true,
      "comparison": "gte",
      "target": 0.99,
      "alert_threshold": 0.99,
      "window": "7d",
      "notes": "중앙 검증 스크립트 통과율."
    },
    {
      "id": "operational_latency_p95_ms",
      "enabled": true,
      "comparison": "lte",
      "target": 2800,
      "alert_threshold": 2800,
      "window": "rolling benchmark window",
      "notes": "성장형 티어의 동기 응답 경로 p95 목표(<2.8s)."
    },
    {
      "id": "d1_return_rate",
      "enabled": true,
      "comparison": "gte",
      "target": 0.2,
      "alert_threshold": 0.15,
      "window": "7d",
      "notes": "학습자 다음날 재방문 비율."
    },
    {
      "id": "vote_completion_rate",
      "enabled": true,
      "comparison": "gte",
      "target": 0.68,
      "alert_threshold": 0.58,
      "window": "3d",
      "notes": "그룹 학습 합의/투표 흐름 완료율."
    },
    {
      "id": "post_vote_result_open_rate",
      "enabled": true,
      "comparison": "gte",
      "target": 0.42,
      "alert_threshold": 0.32,
      "window": "3d",
      "notes": "결과 확인 화면 진입 비율."
    },
    {
      "id": "llm_fallback_rate",
      "enabled": true,
      "comparison": "lte",
      "target": 0.1,
      "alert_threshold": 0.15,
      "window": "24h",
      "notes": "OpenAI 오류/제한 시 safety fallback 비율."
    }
  ]
}
