{
  "version": "v0.1",
  "common_kpi_set": "governance-core-v1",
  "kpis": [
    {
      "id": "explainability_coverage",
      "enabled": true,
      "comparison": "gte",
      "target": 1.0,
      "alert_threshold": 1.0,
      "window": "release-candidate",
      "notes": "Every vault operation decision remains trace-linked."
    },
    {
      "id": "validation_reliability",
      "enabled": true,
      "comparison": "gte",
      "target": 0.99,
      "alert_threshold": 0.99,
      "window": "7d",
      "notes": "Schema and guardrail checks must remain stable."
    },
    {
      "id": "operational_latency_p95_ms",
      "enabled": true,
      "comparison": "lte",
      "target": 1200,
      "alert_threshold": 1200,
      "window": "rolling benchmark window",
      "notes": "Bridge-path p95 latency for vault-read workflows."
    },
    {
      "id": "d1_return_rate",
      "enabled": true,
      "comparison": "gte",
      "target": 0.2,
      "alert_threshold": 0.15,
      "window": "7d",
      "notes": "Sticky usage proxy for knowledge workflows."
    },
    {
      "id": "vote_completion_rate",
      "enabled": true,
      "comparison": "gte",
      "target": 0.65,
      "alert_threshold": 0.55,
      "window": "3d",
      "notes": "Share of requests reaching deterministic verdict."
    },
    {
      "id": "post_vote_result_open_rate",
      "enabled": true,
      "comparison": "gte",
      "target": 0.4,
      "alert_threshold": 0.3,
      "window": "3d",
      "notes": "Share of users reviewing verdict outputs."
    },
    {
      "id": "llm_fallback_rate",
      "enabled": true,
      "comparison": "lte",
      "target": 0.1,
      "alert_threshold": 0.15,
      "window": "24h",
      "notes": "Fallback share for read workflows."
    }
  ]
}
