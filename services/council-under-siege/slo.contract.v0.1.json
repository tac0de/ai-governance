{
  "version": "v0.1",
  "common_kpi_set": "governance-core-v1",
  "kpis": [
    {
      "id": "explainability_coverage",
      "enabled": true,
      "comparison": "gte",
      "target": 1.0,
      "alert_threshold": 1.0,
      "window": "release-candidate",
      "notes": "Every turn decision must have intent, policy, evidence, and trace linkage."
    },
    {
      "id": "validation_reliability",
      "enabled": true,
      "comparison": "gte",
      "target": 0.99,
      "alert_threshold": 0.99,
      "window": "7d",
      "notes": "Governance schema and contract validation pass ratio."
    },
    {
      "id": "operational_latency_p95_ms",
      "enabled": true,
      "comparison": "lte",
      "target": 1200,
      "alert_threshold": 1200,
      "window": "rolling benchmark window",
      "notes": "Governance path p95 latency for one-turn decision runs."
    },
    {
      "id": "d1_return_rate",
      "enabled": true,
      "comparison": "gte",
      "target": 0.2,
      "alert_threshold": 0.15,
      "window": "7d",
      "notes": "Share of users returning on next UTC day."
    },
    {
      "id": "vote_completion_rate",
      "enabled": true,
      "comparison": "gte",
      "target": 0.68,
      "alert_threshold": 0.58,
      "window": "3d",
      "notes": "Share of sessions completing one-turn consensus interaction."
    },
    {
      "id": "post_vote_result_open_rate",
      "enabled": true,
      "comparison": "gte",
      "target": 0.42,
      "alert_threshold": 0.32,
      "window": "3d",
      "notes": "Share of successful sessions that open result view."
    },
    {
      "id": "llm_fallback_rate",
      "enabled": true,
      "comparison": "lte",
      "target": 0.1,
      "alert_threshold": 0.15,
      "window": "24h",
      "notes": "Share of runs requiring safety fallback for model failures."
    }
  ]
}
