{
  "version": "v0.1",
  "common_kpi_set": "governance-core-v1",
  "kpis": [
    {
      "id": "explainability_coverage",
      "enabled": true,
      "comparison": "gte",
      "target": 1.0,
      "alert_threshold": 1.0,
      "window": "release-candidate",
      "notes": "Every shipped decision must include intent, policy, evidence, and trace refs."
    },
    {
      "id": "validation_reliability",
      "enabled": true,
      "comparison": "gte",
      "target": 0.99,
      "alert_threshold": 0.99,
      "window": "7d",
      "notes": "Governance schema and cross-registry validation pass ratio."
    },
    {
      "id": "operational_latency_p95_ms",
      "enabled": true,
      "comparison": "lte",
      "target": 1200,
      "alert_threshold": 1200,
      "window": "rolling benchmark window",
      "notes": "Bridge-path p95 latency for one-turn operations simulation requests."
    },
    {
      "id": "d1_return_rate",
      "enabled": true,
      "comparison": "gte",
      "target": 0.22,
      "alert_threshold": 0.18,
      "window": "7d",
      "notes": "Share of players returning next UTC day."
    },
    {
      "id": "vote_completion_rate",
      "enabled": true,
      "comparison": "gte",
      "target": 0.68,
      "alert_threshold": 0.58,
      "window": "3d",
      "notes": "Share of sessions completing one daily operations decision."
    },
    {
      "id": "post_vote_result_open_rate",
      "enabled": true,
      "comparison": "gte",
      "target": 0.42,
      "alert_threshold": 0.32,
      "window": "3d",
      "notes": "Share of completed sessions opening day result view."
    },
    {
      "id": "llm_fallback_rate",
      "enabled": true,
      "comparison": "lte",
      "target": 0.1,
      "alert_threshold": 0.15,
      "window": "24h",
      "notes": "Share of recompute events degraded to safety fallback."
    }
  ]
}
