{
  "version": "v0.1",
  "common_kpi_set": "governance-core-v1",
  "kpis": [
    {
      "id": "explainability_coverage",
      "enabled": true,
      "comparison": "gte",
      "target": 1.0,
      "alert_threshold": 1.0,
      "window": "release-candidate",
      "notes": "Every governance-side change must retain intent, policy, and evidence linkage."
    },
    {
      "id": "validation_reliability",
      "enabled": true,
      "comparison": "gte",
      "target": 0.99,
      "alert_threshold": 0.99,
      "window": "7d",
      "notes": "Central validation pass ratio for service registration."
    },
    {
      "id": "operational_latency_p95_ms",
      "enabled": true,
      "comparison": "lte",
      "target": 1500,
      "alert_threshold": 1800,
      "window": "rolling benchmark window",
      "notes": "External runtime chapter-response latency target."
    },
    {
      "id": "d1_return_rate",
      "enabled": true,
      "comparison": "gte",
      "target": 0.2,
      "alert_threshold": 0.15,
      "window": "7d",
      "notes": "Day-1 return target for serialized readers."
    },
    {
      "id": "vote_completion_rate",
      "enabled": false,
      "comparison": "n/a",
      "target": null,
      "alert_threshold": null,
      "window": "n/a",
      "notes": "No vote flow exists in the initial release."
    },
    {
      "id": "post_vote_result_open_rate",
      "enabled": false,
      "comparison": "n/a",
      "target": null,
      "alert_threshold": null,
      "window": "n/a",
      "notes": "No vote-result screen exists in the initial release."
    },
    {
      "id": "llm_fallback_rate",
      "enabled": false,
      "comparison": "n/a",
      "target": null,
      "alert_threshold": null,
      "window": "n/a",
      "notes": "Initial reader runtime does not require an LLM verdict path."
    }
  ]
}
