{
  "version": "v0.1",
  "service_id": "thedivineparadox",
  "governance_source_refs": [
    "control/agents/departments.v0.1.json",
    "policies/agent_routing_policy.v0.1.json",
    "policies/approval_tier_policy.v0.1.json",
    "services/thedivineparadox/contract.bundle.v0.1.json",
    "services/thedivineparadox/policy.profile.json"
  ],
  "roles": [
    {
      "role_id": "rebuild-intent-cell",
      "title": "Rebuild Intent Cell",
      "governance_department_id": "service-review",
      "mission": "Define the rebuild scope, archive posture, and trace packet requirements before any contract or runtime work proceeds.",
      "bounded_state_scope": [
        "Reset",
        "Archive",
        "Baseline"
      ],
      "required_inputs": [
        "intent_ref",
        "policy_ref",
        "evidence_ref"
      ],
      "allowed_outputs": [
        "rebuild-intent-note",
        "archive-boundary-note"
      ],
      "output_contract_refs": [
        "schemas/service_agent_proposal.schema.json"
      ],
      "allowed_actions": [
        "pin archive scope",
        "define runtime ownership boundary"
      ],
      "forbidden_actions": [
        "touch runtime code inside ai-governance",
        "skip seed archiving",
        "bypass trace linkage"
      ],
      "evidence_requirements": [
        "Every rebuild packet must cite the runtime repo path and archive destination.",
        "Any replacement contract must reference a trace packet in traces/local."
      ],
      "policy_refs": [
        "policies/agent_routing_policy.v0.1.json",
        "policies/approval_tier_policy.v0.1.json",
        "services/thedivineparadox/policy.profile.json"
      ],
      "handoff_targets": [
        "state-contract-cell"
      ]
    },
    {
      "role_id": "state-contract-cell",
      "title": "State Contract Cell",
      "governance_department_id": "service-review",
      "mission": "Define deterministic state derivation, vote constraints, trace fields, and the public API contract for the runtime rebuild.",
      "bounded_state_scope": [
        "Baseline",
        "QuestionOpen",
        "ChoiceLocked",
        "OracleCached"
      ],
      "required_inputs": [
        "intent_ref",
        "policy_ref",
        "evidence_ref",
        "trace_ref"
      ],
      "allowed_outputs": [
        "state-contract-note",
        "uiux-execution-plan"
      ],
      "output_contract_refs": [
        "schemas/service_agent_proposal.schema.json",
        "schemas/service_agent_plan.schema.json"
      ],
      "allowed_actions": [
        "define deterministic derived-state inputs",
        "bind API contracts to trace metadata"
      ],
      "forbidden_actions": [
        "allow free-form prompt input in the MVP",
        "store raw IP addresses in logs",
        "skip idempotency design"
      ],
      "evidence_requirements": [
        "State derivation must remain reproducible from question text, option labels, and counts.",
        "The plan must name cache and regeneration boundaries."
      ],
      "policy_refs": [
        "policies/approval_tier_policy.v0.1.json",
        "services/thedivineparadox/policy.profile.json"
      ],
      "handoff_targets": [
        "experience-systems-cell"
      ]
    },
    {
      "role_id": "experience-systems-cell",
      "title": "Experience Systems Cell",
      "governance_department_id": "service-review",
      "mission": "Package the mobile-first ritual surface, interaction semantics, and Three.js performance guardrails for the v2 runtime.",
      "bounded_state_scope": [
        "QuestionOpen",
        "ChoiceLocked",
        "OracleCached",
        "ArchiveView"
      ],
      "required_inputs": [
        "intent_ref",
        "policy_ref",
        "evidence_ref",
        "trace_ref",
        "proposal_ref"
      ],
      "allowed_outputs": [
        "interaction-flow-spec",
        "visual-budget-note"
      ],
      "output_contract_refs": [
        "schemas/service_agent_proposal.schema.json"
      ],
      "allowed_actions": [
        "map state vectors to bounded visual parameters",
        "define downgrade behavior for reduced motion and low-power devices"
      ],
      "forbidden_actions": [
        "depend on uncontrolled assets",
        "break mobile-first layout assumptions",
        "ignore performance budgets"
      ],
      "evidence_requirements": [
        "Every visual behavior must be linked to a deterministic state input.",
        "Fallback modes must be explicit and testable."
      ],
      "policy_refs": [
        "control/specs/trace_rules.v0.1.json",
        "services/thedivineparadox/policy.profile.json"
      ],
      "handoff_targets": [
        "runtime-safety-cell"
      ]
    },
    {
      "role_id": "runtime-safety-cell",
      "title": "Runtime Safety Cell",
      "governance_department_id": "policy-ops",
      "mission": "Validate rate limits, safe fallback logic, admin regeneration boundaries, and structured logging requirements before release.",
      "bounded_state_scope": [
        "ChoiceLocked",
        "OracleCached",
        "Fallback",
        "IncidentReview"
      ],
      "required_inputs": [
        "intent_ref",
        "policy_ref",
        "evidence_ref",
        "trace_ref",
        "proposal_ref"
      ],
      "allowed_outputs": [
        "policy-verdict-note",
        "risk-escalation-flag"
      ],
      "output_contract_refs": [
        "schemas/service_agent_proposal.schema.json"
      ],
      "allowed_actions": [
        "check content guardrails",
        "verify deterministic fallback and cache rules"
      ],
      "forbidden_actions": [
        "approve unbounded generation",
        "permit raw IP logging",
        "skip moderation or schema validation"
      ],
      "evidence_requirements": [
        "Unsafe output handling must cite the exact fallback path.",
        "Rate limiting and idempotency expectations must be explicit."
      ],
      "policy_refs": [
        "policies/approval_tier_policy.v0.1.json",
        "policies/agent_routing_policy.v0.1.json",
        "services/thedivineparadox/policy.profile.json"
      ],
      "handoff_targets": [
        "release-gate-cell"
      ]
    },
    {
      "role_id": "release-gate-cell",
      "title": "Release Gate Cell",
      "governance_department_id": "governance-council",
      "mission": "Decide whether the replaced seed, runtime evidence, and validation logs are coherent enough for governed release and cutover review.",
      "bounded_state_scope": [
        "OracleCached",
        "ReleaseReady"
      ],
      "required_inputs": [
        "intent_ref",
        "policy_ref",
        "evidence_ref",
        "trace_ref",
        "verdict_ref"
      ],
      "allowed_outputs": [
        "release-candidate-verdict",
        "hold-notice"
      ],
      "output_contract_refs": [
        "schemas/service_agent_proposal.schema.json"
      ],
      "allowed_actions": [
        "confirm release eligibility",
        "hold for human architect gate"
      ],
      "forbidden_actions": [
        "waive missing archive evidence",
        "ignore runtime validation gaps",
        "merge without rollback context"
      ],
      "evidence_requirements": [
        "Release verdicts must cite runtime path, validation commands, and archive refs.",
        "Any hold notice must point to a concrete remediation path."
      ],
      "policy_refs": [
        "policies/approval_tier_policy.v0.1.json",
        "services/thedivineparadox/policy.profile.json"
      ],
      "handoff_targets": []
    }
  ]
}
