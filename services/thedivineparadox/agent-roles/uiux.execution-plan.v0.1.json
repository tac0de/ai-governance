{
  "version": "v0.1",
  "service_id": "thedivineparadox",
  "plan_id": "tdp-v2-rebuild-2026-03-01",
  "objective": "Drive a governed two-repo rebuild of TheDivineParadox v2 while keeping ai-governance contract-only and moving the runtime into a dedicated mobile-first Next.js repository.",
  "source_refs": [
    "services/thedivineparadox/contract.bundle.v0.1.json",
    "services/thedivineparadox/agent-roles/agent.roles.v0.1.json",
    "services/thedivineparadox/agent-roles/agent.handoffs.v0.1.json",
    "services/thedivineparadox/agent-roles/prompt.strategy.v0.1.json",
    "policies/approval_tier_policy.v0.1.json",
    "policies/agent_routing_policy.v0.1.json"
  ],
  "phases": [
    {
      "phase_id": "phase0-recon-reset",
      "title": "Phase 0 Recon and Reset",
      "owner_role_id": "rebuild-intent-cell",
      "supporting_role_ids": [
        "state-contract-cell"
      ],
      "target_states": [
        "Reset",
        "Archive",
        "Baseline"
      ],
      "deliverables": [
        {
          "deliverable_id": "seed-archive-packet",
          "output_kind": "archive-boundary-note",
          "contract_ref": "schemas/service_agent_proposal.schema.json"
        },
        {
          "deliverable_id": "runtime-boundary-packet",
          "output_kind": "rebuild-intent-note",
          "contract_ref": "schemas/service_agent_proposal.schema.json"
        }
      ],
      "acceptance_checks": [
        "The legacy seed is archived before any live contract is replaced.",
        "The runtime repo path is explicit and ai-governance remains JSON-only."
      ]
    },
    {
      "phase_id": "phase1-backbone",
      "title": "Phase 1 Backbone",
      "owner_role_id": "state-contract-cell",
      "supporting_role_ids": [
        "experience-systems-cell"
      ],
      "target_states": [
        "Baseline",
        "QuestionOpen",
        "ChoiceLocked"
      ],
      "deliverables": [
        {
          "deliverable_id": "deterministic-state-contract",
          "output_kind": "state-contract-note",
          "contract_ref": "schemas/service_agent_proposal.schema.json"
        },
        {
          "deliverable_id": "runtime-phase-plan",
          "output_kind": "uiux-execution-plan",
          "contract_ref": "schemas/service_agent_plan.schema.json"
        }
      ],
      "acceptance_checks": [
        "The derived state function is fully deterministic and non-AI.",
        "Vote idempotency, one-vote-per-day, and cache rules are explicit."
      ]
    },
    {
      "phase_id": "phase2-experience",
      "title": "Phase 2 Experience",
      "owner_role_id": "experience-systems-cell",
      "supporting_role_ids": [
        "state-contract-cell"
      ],
      "target_states": [
        "QuestionOpen",
        "ChoiceLocked",
        "OracleCached",
        "ArchiveView"
      ],
      "deliverables": [
        {
          "deliverable_id": "interaction-contract",
          "output_kind": "interaction-flow-spec",
          "contract_ref": "schemas/service_agent_proposal.schema.json"
        },
        {
          "deliverable_id": "performance-guardrails",
          "output_kind": "visual-budget-note",
          "contract_ref": "schemas/service_agent_proposal.schema.json"
        }
      ],
      "acceptance_checks": [
        "The mobile-first surface remains legible and intentional on a mid-tier handset.",
        "Three.js behavior degrades cleanly to reduced-motion or static fallback."
      ]
    },
    {
      "phase_id": "phase3-hardening",
      "title": "Phase 3 Hardening",
      "owner_role_id": "runtime-safety-cell",
      "supporting_role_ids": [
        "release-gate-cell"
      ],
      "target_states": [
        "ChoiceLocked",
        "OracleCached",
        "Fallback",
        "IncidentReview"
      ],
      "deliverables": [
        {
          "deliverable_id": "safety-verdict-packet",
          "output_kind": "policy-verdict-note",
          "contract_ref": "schemas/service_agent_proposal.schema.json"
        },
        {
          "deliverable_id": "escalation-ledger",
          "output_kind": "risk-escalation-flag",
          "contract_ref": "schemas/service_agent_proposal.schema.json"
        }
      ],
      "acceptance_checks": [
        "Every oracle path is bounded, validated, and logged with fallback behavior.",
        "Rate limits, idempotency, and admin regeneration boundaries are explicit."
      ]
    },
    {
      "phase_id": "phase4-evidence-release",
      "title": "Phase 4 Evidence and Release",
      "owner_role_id": "release-gate-cell",
      "supporting_role_ids": [
        "runtime-safety-cell"
      ],
      "target_states": [
        "OracleCached",
        "ReleaseReady"
      ],
      "deliverables": [
        {
          "deliverable_id": "release-verdict-packet",
          "output_kind": "release-candidate-verdict",
          "contract_ref": "schemas/service_agent_proposal.schema.json"
        },
        {
          "deliverable_id": "release-hold-packet",
          "output_kind": "hold-notice",
          "contract_ref": "schemas/service_agent_proposal.schema.json"
        }
      ],
      "acceptance_checks": [
        "Runtime evidence includes validation commands, archive refs, and runtime commit context.",
        "Any hold condition names a concrete rollback or remediation path."
      ]
    }
  ],
  "release_gate": {
    "owner_role_id": "release-gate-cell",
    "required_inputs": [
      "intent_ref",
      "policy_ref",
      "evidence_ref",
      "trace_ref",
      "verdict_ref"
    ],
    "blocking_conditions": [
      "Any package that omits archive evidence or runtime validation results.",
      "Any change that adds new external permissions outside the declared scope.",
      "Any high-tier change without an explicit human architect gate."
    ]
  }
}
