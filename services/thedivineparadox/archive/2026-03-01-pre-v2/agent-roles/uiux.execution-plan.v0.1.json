{
  "version": "v0.1",
  "service_id": "thedivineparadox",
  "plan_id": "tdp-uiux-orchestration-2026-03-01",
  "objective": "Prepare a governed UI and UX evolution plan that sharpens ritual clarity, emotional differentiation, and cross-device gesture parity without moving product runtime implementation into ai-governance.",
  "source_refs": [
    "services/thedivineparadox/contract.bundle.v0.1.json",
    "services/thedivineparadox/agent-roles/agent.roles.v0.1.json",
    "services/thedivineparadox/agent-roles/agent.handoffs.v0.1.json",
    "policies/approval_tier_policy.v0.1.json",
    "policies/agent_routing_policy.v0.1.json"
  ],
  "phases": [
    {
      "phase_id": "ritual-legibility-baseline",
      "title": "Ritual Legibility Baseline",
      "owner_role_id": "ux-research-cell",
      "supporting_role_ids": [
        "ritual-narrative-cell"
      ],
      "target_states": [
        "Dormant",
        "Awakening",
        "Attuning"
      ],
      "deliverables": [
        {
          "deliverable_id": "first-session-friction-map",
          "output_kind": "ui-ux-evidence-brief",
          "contract_ref": "schemas/service_agent_proposal.schema.json"
        },
        {
          "deliverable_id": "narrative-entry-guardrails",
          "output_kind": "narrative-brief",
          "contract_ref": "schemas/service_agent_proposal.schema.json"
        }
      ],
      "acceptance_checks": [
        "A first-time user should infer the ritual action within the first 10 seconds.",
        "Narrative framing must preserve the current contract boundary and passive fallback."
      ]
    },
    {
      "phase_id": "interaction-parity-package",
      "title": "Interaction Parity Package",
      "owner_role_id": "interaction-orchestration-cell",
      "supporting_role_ids": [
        "ux-research-cell"
      ],
      "target_states": [
        "Attuning",
        "Offering",
        "JudgementBloom"
      ],
      "deliverables": [
        {
          "deliverable_id": "gesture-semantic-map",
          "output_kind": "interaction-flow-spec",
          "contract_ref": "schemas/service_agent_proposal.schema.json"
        },
        {
          "deliverable_id": "feedback-loop-constraints",
          "output_kind": "state-entry-constraint-note",
          "contract_ref": "schemas/service_agent_proposal.schema.json"
        }
      ],
      "acceptance_checks": [
        "Core ritual semantics should remain legible on both PC pointer input and mobile touch or motion input.",
        "Swipe, pinch, long press, and tilt should map to bounded semantic channels without adding extra hidden states."
      ]
    },
    {
      "phase_id": "visual-differentiation-pass",
      "title": "Visual Differentiation Pass",
      "owner_role_id": "visual-systems-cell",
      "supporting_role_ids": [
        "interaction-orchestration-cell"
      ],
      "target_states": [
        "JudgementBloom",
        "Revelation",
        "Afterglow"
      ],
      "deliverables": [
        {
          "deliverable_id": "state-differentiation-grid",
          "output_kind": "visual-modulation-brief",
          "contract_ref": "schemas/service_agent_proposal.schema.json"
        },
        {
          "deliverable_id": "rendering-budget-guardrails",
          "output_kind": "state-differentiation-note",
          "contract_ref": "schemas/service_agent_proposal.schema.json"
        }
      ],
      "acceptance_checks": [
        "Each phase should remain visually distinguishable from a single screenshot.",
        "Theme transitions should not cause severe frame drops on mid-tier GPUs."
      ]
    },
    {
      "phase_id": "governance-release-check",
      "title": "Governance Release Check",
      "owner_role_id": "policy-safety-cell",
      "supporting_role_ids": [
        "release-gate-cell"
      ],
      "target_states": [
        "Revelation",
        "Afterglow"
      ],
      "deliverables": [
        {
          "deliverable_id": "policy-verdict-packet",
          "output_kind": "policy-verdict-note",
          "contract_ref": "schemas/service_agent_proposal.schema.json"
        }
      ],
      "acceptance_checks": [
        "Every final package must retain intent, policy, and evidence linkage.",
        "High-tier changes must remain held until the human gate is satisfied."
      ]
    }
  ],
  "release_gate": {
    "owner_role_id": "release-gate-cell",
    "required_inputs": [
      "intent_ref",
      "policy_ref",
      "evidence_ref",
      "trace_ref",
      "verdict_ref"
    ],
    "blocking_conditions": [
      "Any requested change that expands runtime permissions or external API scope.",
      "Any package that omits target state mapping or output-contract references.",
      "Any high-tier change without an explicit human architect gate."
    ]
  }
}
