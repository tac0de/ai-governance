{
  "version": "v0.1",
  "purpose": "Compare service operating models under equal quality targets",
  "comparison_groups": {
    "baseline": "realtime_1to1_llm",
    "candidate": "tiered_a_b_c_cache_first"
  },
  "scales": [
    "1k_dau",
    "10k_dau",
    "100k_dau"
  ],
  "required_conditions": {
    "same_quality_target": true,
    "same_sla_target": true,
    "same_time_window_days": 28
  },
  "kpi_thresholds": {
    "min_acceptance_pass_rate": 0.98,
    "min_cache_hit_rate": 0.8,
    "max_fallback_rate": 0.05,
    "min_cost_reduction_vs_baseline": 0.3
  }
}
