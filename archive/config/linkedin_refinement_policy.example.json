{
  "version": "0.2.0",
  "mode": {
    "thought_refinement_mode": true,
    "auto_publish": false,
    "emotion_tag_required": true
  },
  "limits": {
    "min_review_delay_hours": 24,
    "max_posts_per_week": 2
  },
  "input": {
    "allowed_sources": [
      "weekly_note_summary",
      "project_change_log",
      "failure_record",
      "personal_note"
    ],
    "facts_first": true
  },
  "distillation": {
    "compression_target_ratio": 0.3,
    "structure": ["problem", "experiment", "result", "lesson"]
  },
  "integrity_filter": {
    "exaggeration_detection": true,
    "neutralize_personal_attacks": true,
    "warn_sensitive_terms": ["financial", "legal", "privacy"],
    "certainty_to_observation": true
  },
  "state_guard": {
    "required_questions": [
      "is_verifiable",
      "is_not_exaggerated",
      "future_self_agreement"
    ],
    "block_publish_if_any_no": true
  },
  "archive": {
    "save_unpublished_drafts": true,
    "asset_priority": "thought_archive"
  }
}
