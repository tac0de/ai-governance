{
  "version": "1.0.0",
  "mode": {
    "auto_charge": false,
    "auto_refund": false,
    "human_gate_required_for_real_billing": true
  },
  "limits": {
    "monthly_usd_cap": 500,
    "per_service_usd_cap": 100
  },
  "phase_1_human_required": [
    "settlement_method_registered",
    "kyc_completed",
    "tax_profile_completed",
    "payout_account_verified"
  ],
  "phase_2_automation": {
    "catalog_sync": true,
    "checkout_config_sync": true,
    "webhook_verify_signature": true,
    "access_grant_on_paid": true,
    "retry_failed_events": true,
    "daily_reconciliation_report": true
  },
  "audit": {
    "required_fields": [
      "timestamp",
      "actor",
      "reason",
      "change_summary",
      "rollback_ref"
    ],
    "append_only": true
  }
}
