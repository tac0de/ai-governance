{
  "version": "v0.1",
  "purpose": "Risk-tiered approval policy for service automation",
  "tiers": {
    "low": {
      "approval_mode": "auto",
      "requirements": [
        "all acceptance tests pass",
        "no secret policy change",
        "no external permission escalation"
      ]
    },
    "medium": {
      "approval_mode": "policy_plus_owner",
      "requirements": [
        "all acceptance tests pass",
        "policy review completed",
        "human owner approval recorded"
      ]
    },
    "high": {
      "approval_mode": "mandatory_human_gate",
      "requirements": [
        "all acceptance tests pass",
        "security impact reviewed",
        "explicit human architect approval"
      ]
    }
  }
}
