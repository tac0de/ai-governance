#!/usr/bin/env bash
set -euo pipefail

# Block obvious secret leaks before commit.
# Keep rule small to reduce false positives.

staged_files="$(git diff --cached --name-only --diff-filter=ACM)"
if [[ -z "${staged_files}" ]]; then
  exit 0
fi

if echo "${staged_files}" | rg -q '(^|/)\.env$'; then
  echo "[SECURITY] .env file is staged. Remove it before commit."
  exit 1
fi

patterns=(
  'sk-[A-Za-z0-9]{20,}'
  'sk-proj-[A-Za-z0-9_-]{20,}'
  'ghp_[A-Za-z0-9]{20,}'
  'gho_[A-Za-z0-9]{20,}'
  'github_pat_[A-Za-z0-9_]{20,}'
  'AIza[0-9A-Za-z\-_]{35}'
)

for f in ${staged_files}; do
  if [[ -f "${f}" ]]; then
    for p in "${patterns[@]}"; do
      if rg -n --pcre2 "${p}" "${f}" >/dev/null 2>&1; then
        echo "[SECURITY] Potential secret detected in ${f}"
        echo "Pattern: ${p}"
        exit 1
      fi
    done
  fi
done

if [[ -x "scripts/sync_hub_guard.sh" ]]; then
  bash scripts/sync_hub_guard.sh pre-commit
fi

if [[ -x "scripts/lint_obsidian_tags.sh" ]]; then
  bash scripts/lint_obsidian_tags.sh repo
fi

exit 0
