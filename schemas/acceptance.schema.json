{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AcceptanceTests",
  "type": "object",
  "required": ["must_include_sources", "max_hallucination_score", "required_sections"],
  "properties": {
    "must_include_sources": { "type": "boolean" },
    "max_hallucination_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "required_sections": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
