{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ServicePromptStrategy",
  "type": "object",
  "required": [
    "version",
    "service_id",
    "strategy_mode",
    "roles",
    "global_guardrails"
  ],
  "properties": {
    "version": { "type": "string", "const": "v0.1" },
    "service_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "strategy_mode": { "type": "string", "enum": ["standard", "ritual-uiux"] },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "role_id",
          "prompt_mode",
          "allowed_prompt_scopes",
          "forbidden_prompt_patterns",
          "required_refs"
        ],
        "properties": {
          "role_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "prompt_mode": { "type": "string", "minLength": 1 },
          "allowed_prompt_scopes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "forbidden_prompt_patterns": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "required_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    },
    "global_guardrails": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
