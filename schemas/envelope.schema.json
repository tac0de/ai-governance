{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IntentEnvelope",
  "type": "object",
  "required": ["intent_id", "policy_profile", "state_ref", "plan_ref", "budget", "acceptance_tests_ref"],
  "properties": {
    "intent_id": { "type": "string", "minLength": 1 },
    "policy_profile": { "type": "string", "enum": ["strict", "balanced", "creative"] },
    "state_ref": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "plan_ref": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "budget": {
      "type": "object",
      "required": ["max_tokens", "max_steps"],
      "properties": {
        "max_tokens": { "type": "integer", "minimum": 1 },
        "max_steps": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "acceptance_tests_ref": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }
  },
  "additionalProperties": false
}
