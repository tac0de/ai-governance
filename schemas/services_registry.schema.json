{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ServiceSeedCatalog",
  "type": "object",
  "required": ["version", "services"],
  "properties": {
    "version": {
      "type": "string",
      "const": "v0.1"
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "catalog_role",
          "owner",
          "seed_path",
          "bootstrap_profile",
          "contract_bundle_ref",
          "agent_roles_ref",
          "agent_handoffs_ref",
          "default_policy_profile_ref",
          "default_mcp_allowlist_ref",
          "default_slo_contract_ref",
          "notes"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "name": { "type": "string", "minLength": 1 },
          "catalog_role": {
            "type": "string",
            "const": "archived-seed-example"
          },
          "owner": { "type": "string", "minLength": 1 },
          "seed_path": {
            "type": "string",
            "pattern": "^services/[a-z0-9][a-z0-9-]*$"
          },
          "bootstrap_profile": {
            "type": "string",
            "enum": ["standard", "ritual-uiux"]
          },
          "contract_bundle_ref": {
            "type": "string",
            "pattern": "^services/[a-z0-9][a-z0-9-]*/contract\\.bundle\\.v0\\.1\\.json$"
          },
          "agent_roles_ref": {
            "type": "string",
            "pattern": "^services/[a-z0-9][a-z0-9-]*/agent-roles/agent\\.roles\\.v0\\.1\\.json$"
          },
          "agent_handoffs_ref": {
            "type": "string",
            "pattern": "^services/[a-z0-9][a-z0-9-]*/agent-roles/agent\\.handoffs\\.v0\\.1\\.json$"
          },
          "default_policy_profile_ref": { "type": "string", "minLength": 1 },
          "default_mcp_allowlist_ref": { "type": "string", "minLength": 1 },
          "default_slo_contract_ref": { "type": "string", "minLength": 1 },
          "notes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
