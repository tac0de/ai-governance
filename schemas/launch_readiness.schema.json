{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LaunchReadinessPolicy",
  "type": "object",
  "required": [
    "version",
    "policy_id",
    "definition",
    "gates",
    "promotion_effect",
    "anti_patterns"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v0.6"
    },
    "policy_id": {
      "type": "string",
      "const": "launch-readiness"
    },
    "definition": {
      "type": "object",
      "required": [
        "pre_launch",
        "launch_ready"
      ],
      "properties": {
        "pre_launch": {
          "type": "string",
          "minLength": 1
        },
        "launch_ready": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "gates": {
      "type": "object",
      "required": [
        "required_all",
        "required_checks",
        "freshness_window_days"
      ],
      "properties": {
        "required_all": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "gate_id",
              "evidence_type",
              "rule",
              "notes"
            ],
            "properties": {
              "gate_id": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              },
              "evidence_type": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              },
              "rule": {
                "type": "string",
                "const": "must-exist"
              },
              "notes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false
          }
        },
        "required_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "check_id",
              "rule",
              "notes"
            ],
            "properties": {
              "check_id": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              },
              "rule": {
                "type": "string",
                "const": "must-pass"
              },
              "notes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false
          }
        },
        "freshness_window_days": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "promotion_effect": {
      "type": "object",
      "required": [
        "allows_release_review_signal",
        "blocks_v1_without_version_promotion"
      ],
      "properties": {
        "allows_release_review_signal": {
          "type": "string",
          "const": "promotable"
        },
        "blocks_v1_without_version_promotion": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "anti_patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
