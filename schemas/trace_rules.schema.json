{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeterministicTraceRules",
  "type": "object",
  "required": [
    "version",
    "append_only",
    "hash_reference_required",
    "allowed_record_types",
    "forbidden_mutations",
    "retention_model",
    "journal_export_boundary"
  ],
  "properties": {
    "version": { "type": "string", "const": "v0.1" },
    "append_only": { "type": "boolean", "const": true },
    "hash_reference_required": { "type": "boolean", "const": true },
    "allowed_record_types": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "forbidden_mutations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "retention_model": {
      "type": "object",
      "required": ["primary_store", "export_path", "notes"],
      "properties": {
        "primary_store": { "type": "string", "minLength": 1 },
        "export_path": { "type": "string", "minLength": 1 },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "journal_export_boundary": {
      "type": "object",
      "required": ["mcp_id", "target_service", "requirements"],
      "properties": {
        "mcp_id": { "type": "string", "pattern": "^core-[a-z0-9][a-z0-9-]*$" },
        "target_service": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "requirements": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
