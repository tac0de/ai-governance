{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeterministicTraceRules",
  "type": "object",
  "required": [
    "version",
    "append_only",
    "hash_reference_required",
    "allowed_record_types",
    "forbidden_mutations",
    "retention_model",
    "dtp",
    "telemetry_sync_boundary"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v0.7"
    },
    "append_only": {
      "type": "boolean",
      "const": true
    },
    "hash_reference_required": {
      "type": "boolean",
      "const": true
    },
    "allowed_record_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_mutations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "retention_model": {
      "type": "object",
      "required": [
        "primary_store",
        "export_path",
        "notes"
      ],
      "properties": {
        "primary_store": {
          "type": "string",
          "minLength": 1
        },
        "export_path": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "dtp": {
      "type": "object",
      "required": [
        "root_path",
        "required_paths",
        "fixed_genesis_prev_hash",
        "journal_index_required_fields",
        "validator_receipt_required_fields",
        "validator_checks"
      ],
      "properties": {
        "root_path": {
          "type": "string",
          "minLength": 1
        },
        "required_paths": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "fixed_genesis_prev_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "journal_index_required_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "validator_receipt_required_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "validator_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "telemetry_sync_boundary": {
      "type": "object",
      "required": [
        "transport",
        "ownership",
        "required_payloads",
        "requirements"
      ],
      "properties": {
        "transport": {
          "type": "string",
          "const": "http-api"
        },
        "ownership": {
          "type": "string",
          "const": "service-local"
        },
        "required_payloads": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requirements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
