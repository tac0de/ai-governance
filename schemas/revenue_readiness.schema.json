{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RevenueReadiness",
  "type": "object",
  "required": [
    "version",
    "model",
    "purpose",
    "required_fields",
    "commercial_readiness_status_values",
    "delivery_modes",
    "hard_rules"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v0.7"
    },
    "model": {
      "type": "string",
      "const": "revenue-readiness"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "required_fields": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9_]*$"
      }
    },
    "commercial_readiness_status_values": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "delivery_modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "hard_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
