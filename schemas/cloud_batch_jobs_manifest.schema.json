{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CloudBatchJobsManifest",
  "type": "object",
  "required": ["version", "service_id", "run_id", "jobs"],
  "properties": {
    "version": { "type": "string", "const": "v0.1" },
    "service_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "run_id": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$" },
    "jobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["job_id", "objective_ref", "input_artifacts", "expected_outputs"],
        "properties": {
          "job_id": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$" },
          "objective_ref": { "type": "string", "minLength": 1 },
          "input_artifacts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path", "sha256", "role"],
              "properties": {
                "path": { "type": "string", "minLength": 1 },
                "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "role": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          },
          "expected_outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["role"],
              "properties": {
                "role": { "type": "string", "minLength": 1 },
                "required": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
