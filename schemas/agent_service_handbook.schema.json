{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentServiceHandbook",
  "type": "object",
  "required": [
    "version",
    "model",
    "purpose",
    "handbook_id",
    "required_sections",
    "entry_sequence",
    "forbidden_actions_before_read",
    "service_surface_refs",
    "decision_gates"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v0.7"
    },
    "model": {
      "type": "string",
      "const": "agent-service-handbook"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "handbook_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "required_sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "entry_sequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "forbidden_actions_before_read": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "service_surface_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decision_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
