{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReflectionPacket",
  "type": "object",
  "required": [
    "problem_statement",
    "evidence_refs",
    "root_cause_chain",
    "fix_action",
    "owner",
    "due_date_ref",
    "severity",
    "status"
  ],
  "properties": {
    "problem_statement": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "root_cause_chain": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fix_action": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "due_date_ref": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "in-progress",
        "closed"
      ]
    }
  },
  "additionalProperties": false
}
