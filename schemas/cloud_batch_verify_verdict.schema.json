{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CloudBatchVerifyVerdict",
  "type": "object",
  "required": [
    "version",
    "service_id",
    "run_id",
    "strictness",
    "verification_status",
    "metrics",
    "fail_reasons",
    "warnings"
  ],
  "properties": {
    "version": { "type": "string", "const": "v0.1" },
    "service_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "run_id": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$" },
    "strictness": { "type": "string", "enum": ["hybrid", "strict", "soft"] },
    "verification_status": { "type": "string", "enum": ["pass", "fail"] },
    "metrics": {
      "type": "object",
      "required": [
        "total_jobs",
        "success_jobs",
        "failed_jobs",
        "tokens_in_total",
        "tokens_out_total",
        "max_latency_ms",
        "fail_rate",
        "artifact_checks"
      ],
      "properties": {
        "total_jobs": { "type": "number", "minimum": 0 },
        "success_jobs": { "type": "number", "minimum": 0 },
        "failed_jobs": { "type": "number", "minimum": 0 },
        "tokens_in_total": { "type": "number", "minimum": 0 },
        "tokens_out_total": { "type": "number", "minimum": 0 },
        "max_latency_ms": { "type": "number", "minimum": 0 },
        "fail_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "artifact_checks": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "fail_reasons": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
