{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CloudBatchResultsManifest",
  "type": "object",
  "required": ["version", "service_id", "run_id", "results"],
  "properties": {
    "version": { "type": "string", "const": "v0.1" },
    "service_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "run_id": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$" },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["job_id", "status", "artifacts", "usage"],
        "properties": {
          "job_id": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$" },
          "status": { "type": "string", "enum": ["success", "failed", "timeout", "canceled"] },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path", "sha256", "role"],
              "properties": {
                "path": { "type": "string", "minLength": 1 },
                "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
                "role": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          },
          "usage": {
            "type": "object",
            "required": ["tokens_in", "tokens_out", "latency_ms"],
            "properties": {
              "tokens_in": { "type": "number", "minimum": 0 },
              "tokens_out": { "type": "number", "minimum": 0 },
              "latency_ms": { "type": "number", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
