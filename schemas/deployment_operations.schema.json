{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeploymentOperations",
  "type": "object",
  "required": [
    "version",
    "model",
    "purpose",
    "required_topology_fields",
    "platform_values",
    "domain_routing_modes",
    "certificate_modes",
    "ingress_modes",
    "hard_rules",
    "review_focus"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v0.7"
    },
    "model": {
      "type": "string",
      "const": "deployment-operations"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "required_topology_fields": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      }
    },
    "platform_values": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "domain_routing_modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "certificate_modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "ingress_modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "hard_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "review_focus": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    }
  },
  "additionalProperties": false
}
