{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ServiceSnapshot",
  "type": "object",
  "required": [
    "version",
    "service_id",
    "service_root_profile",
    "snapshot_id",
    "tree_hash",
    "trace_head",
    "present_paths",
    "protected_paths",
    "large_directories",
    "duplicate_surfaces",
    "stale_surfaces",
    "runtime_tooling",
    "orchestration_surface_status",
    "prompt_pack_status"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v0.7"
    },
    "service_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "service_root_profile": {
      "type": "string",
      "enum": [
        "web-runtime",
        "tool-runtime",
        "worker-runtime"
      ]
    },
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "tree_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "trace_head": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$|^none$"
    },
    "present_paths": {
      "$ref": "#/$defs/stringList"
    },
    "protected_paths": {
      "$ref": "#/$defs/stringList"
    },
    "large_directories": {
      "$ref": "#/$defs/stringList"
    },
    "duplicate_surfaces": {
      "$ref": "#/$defs/stringList"
    },
    "stale_surfaces": {
      "$ref": "#/$defs/stringList"
    },
    "runtime_tooling": {
      "$ref": "#/$defs/stringList"
    },
    "orchestration_surface_status": {
      "type": "string",
      "enum": [
        "present",
        "partial",
        "missing"
      ]
    },
    "prompt_pack_status": {
      "type": "string",
      "enum": [
        "present",
        "partial",
        "missing"
      ]
    }
  },
  "$defs": {
    "stringList": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
