{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BenchmarkKPI",
  "type": "object",
  "required": [
    "service_id",
    "window_days",
    "scale",
    "group",
    "acceptance_pass_rate",
    "cache_hit_rate",
    "fallback_rate",
    "cost_per_successful_session_usd",
    "p95_latency_ms"
  ],
  "properties": {
    "service_id": { "type": "string", "minLength": 1 },
    "window_days": { "type": "integer", "minimum": 1 },
    "scale": { "type": "string", "enum": ["1k_dau", "10k_dau", "100k_dau"] },
    "group": { "type": "string", "enum": ["baseline", "candidate"] },
    "acceptance_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "cache_hit_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "fallback_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "cost_per_successful_session_usd": { "type": "number", "minimum": 0 },
    "p95_latency_ms": { "type": "number", "minimum": 0 }
  },
  "additionalProperties": false
}
