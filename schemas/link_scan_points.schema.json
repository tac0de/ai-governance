{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LinkScanPoints",
  "type": "object",
  "required": [
    "version",
    "model",
    "purpose",
    "lane_minimums",
    "scan_points"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v0.6"
    },
    "model": {
      "type": "string",
      "const": "link-scan-catalog"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "lane_minimums": {
      "type": "object",
      "required": [
        "exploration",
        "production"
      ],
      "properties": {
        "exploration": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        },
        "production": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        }
      },
      "additionalProperties": false
    },
    "scan_points": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": [
          "id",
          "order",
          "phase_gate",
          "purpose",
          "required_fields",
          "fail_if_missing",
          "blocks_release"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "phase_gate": {
            "type": "string",
            "enum": [
              "request",
              "grant",
              "review",
              "release"
            ]
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "required_fields": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9_]*$"
            }
          },
          "fail_if_missing": {
            "type": "boolean"
          },
          "blocks_release": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
