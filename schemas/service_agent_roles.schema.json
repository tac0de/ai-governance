{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ServiceAgentRoles",
  "type": "object",
  "required": [
    "version",
    "service_id",
    "governance_source_refs",
    "roles"
  ],
  "properties": {
    "version": { "type": "string", "const": "v0.1" },
    "service_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "governance_source_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "role_id",
          "title",
          "governance_department_id",
          "mission",
          "bounded_state_scope",
          "required_inputs",
          "allowed_outputs",
          "output_contract_refs",
          "allowed_actions",
          "forbidden_actions",
          "evidence_requirements",
          "policy_refs",
          "handoff_targets"
        ],
        "properties": {
          "role_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "title": { "type": "string", "minLength": 1 },
          "governance_department_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "mission": { "type": "string", "minLength": 1 },
          "bounded_state_scope": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "required_inputs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "allowed_outputs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "output_contract_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "allowed_actions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "forbidden_actions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "evidence_requirements": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "policy_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "handoff_targets": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
