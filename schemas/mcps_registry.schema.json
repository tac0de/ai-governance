{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "McpRegistry",
  "type": "object",
  "required": ["version", "mcps"],
  "properties": {
    "version": {
      "type": "string",
      "const": "v0.1"
    },
    "mcps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "root_path",
          "version",
          "capabilities",
          "risk_level",
          "required_approval_tier"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "name": { "type": "string", "minLength": 1 },
          "root_path": { "type": "string", "pattern": "^control/mcps/[a-z0-9][a-z0-9-]*$" },
          "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
          "capabilities": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
          "required_approval_tier": { "type": "string", "enum": ["low", "medium", "high"] },
          "pinned_ref_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
