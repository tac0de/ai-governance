{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ServiceAgentPlan",
  "type": "object",
  "required": [
    "version",
    "service_id",
    "plan_id",
    "objective",
    "source_refs",
    "phases",
    "release_gate"
  ],
  "properties": {
    "version": { "type": "string", "const": "v0.1" },
    "service_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "plan_id": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$" },
    "objective": { "type": "string", "minLength": 1 },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "phase_id",
          "title",
          "owner_role_id",
          "supporting_role_ids",
          "target_states",
          "deliverables",
          "acceptance_checks"
        ],
        "properties": {
          "phase_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "title": { "type": "string", "minLength": 1 },
          "owner_role_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "supporting_role_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
            "uniqueItems": true
          },
          "target_states": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "deliverables": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "deliverable_id",
                "output_kind",
                "contract_ref"
              ],
              "properties": {
                "deliverable_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
                "output_kind": { "type": "string", "minLength": 1 },
                "contract_ref": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          },
          "acceptance_checks": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    },
    "release_gate": {
      "type": "object",
      "required": [
        "owner_role_id",
        "required_inputs",
        "blocking_conditions"
      ],
      "properties": {
        "owner_role_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "required_inputs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "blocking_conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
