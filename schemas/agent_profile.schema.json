{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentProfile",
  "type": "object",
  "required": [
    "version",
    "id",
    "name",
    "provider",
    "default_prompt_pack_id",
    "recommended_for",
    "known_failure_modes",
    "tooling_assumptions"
  ],
  "properties": {
    "version": { "type": "string", "const": "v0.1" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "name": { "type": "string", "minLength": 1 },
    "provider": {
      "type": "string",
      "enum": ["openai", "google", "anthropic", "other"]
    },
    "default_prompt_pack_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "recommended_for": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "known_failure_modes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "tooling_assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}

