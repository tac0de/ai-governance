{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ServiceContractBundle",
  "type": "object",
  "required": [
    "version",
    "service_id",
    "summary",
    "purpose",
    "owner_role",
    "governance_scope",
    "runbook",
    "risk",
    "data_contract",
    "integrations",
    "slo_notes",
    "change_log"
  ],
  "properties": {
    "version": { "type": "string", "const": "v0.1" },
    "service_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "summary": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "owner_role": { "type": "string", "const": "architect-owner" },
    "governance_scope": {
      "type": "object",
      "required": [
        "execution_path",
        "approval_boundary",
        "forbidden_actions",
        "scope_in",
        "scope_out",
        "dependencies",
        "primary_users"
      ],
      "properties": {
        "execution_path": { "type": "string", "minLength": 1 },
        "approval_boundary": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "forbidden_actions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "scope_in": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "scope_out": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "dependencies": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "primary_users": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "decision_principles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "runbook": {
      "type": "object",
      "required": ["start_conditions", "steady_state", "failure_response", "rollback_reference"],
      "properties": {
        "start_conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "steady_state": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "failure_response": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "rollback_reference": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "access_revocation": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "risk": {
      "type": "object",
      "required": ["tier", "failure_modes", "mandatory_controls"],
      "properties": {
        "tier": { "type": "string", "enum": ["low", "medium", "high"] },
        "failure_modes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "mandatory_controls": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "data_contract": {
      "type": "object",
      "required": [
        "classification",
        "pii_allowed",
        "primary_artifacts",
        "retention_policy",
        "journal_export_policy",
        "access_controls"
      ],
      "properties": {
        "classification": { "type": "string", "minLength": 1 },
        "pii_allowed": { "type": "boolean" },
        "primary_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "retention_policy": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "journal_export_policy": {
          "type": "object",
          "required": ["mode", "target_service", "conditions"],
          "properties": {
            "mode": { "type": "string", "enum": ["disabled", "conditional", "required"] },
            "target_service": {
              "type": ["string", "null"],
              "pattern": "^[a-z0-9][a-z0-9-]*$"
            },
            "conditions": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "additionalProperties": false
        },
        "access_controls": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "integrations": {
      "type": "object",
      "required": ["allowed_mcp_ids", "external_runtime_refs", "governance_interfaces"],
      "properties": {
        "allowed_mcp_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^core-[a-z0-9][a-z0-9-]*$" },
          "uniqueItems": true
        },
        "external_runtime_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "governance_interfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "extension_baseline": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "permissions_scope": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "experience_contract": {
      "type": "object",
      "required": [
        "experience_model",
        "primary_emotion_axis",
        "interaction_axis",
        "core_presence",
        "emotional_skins",
        "interaction_ritual",
        "scene_state_contract",
        "interaction_event_model",
        "visual_modulation_contract",
        "test_scenarios"
      ],
      "properties": {
        "experience_model": { "type": "string", "minLength": 1 },
        "primary_emotion_axis": { "type": "string", "minLength": 1 },
        "interaction_axis": { "type": "string", "minLength": 1 },
        "core_presence": {
          "type": "object",
          "required": ["summary", "persistent_cues", "relationship_distance_model"],
          "properties": {
            "summary": { "type": "string", "minLength": 1 },
            "persistent_cues": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "relationship_distance_model": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "emotional_skins": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "theme_id",
              "display_name",
              "emotion_profile",
              "visual_profile",
              "audio_profile",
              "interaction_response_profile",
              "result_reveal_style",
              "transition_rules"
            ],
            "properties": {
              "theme_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
              "display_name": { "type": "string", "minLength": 1 },
              "emotion_profile": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "visual_profile": {
                "type": "object",
                "required": ["signature_motifs", "dominant_layers", "key_effect_bias"],
                "properties": {
                  "signature_motifs": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "dominant_layers": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "key_effect_bias": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 2,
                    "items": { "type": "string", "minLength": 1 }
                  }
                },
                "additionalProperties": false
              },
              "audio_profile": {
                "type": "object",
                "required": ["energy", "texture"],
                "properties": {
                  "energy": { "type": "string", "minLength": 1 },
                  "texture": { "type": "string", "minLength": 1 }
                },
                "additionalProperties": false
              },
              "interaction_response_profile": {
                "type": "object",
                "required": ["invocation", "offering", "alignment"],
                "properties": {
                  "invocation": { "type": "string", "minLength": 1 },
                  "offering": { "type": "string", "minLength": 1 },
                  "alignment": { "type": "string", "minLength": 1 }
                },
                "additionalProperties": false
              },
              "result_reveal_style": { "type": "string", "minLength": 1 },
              "transition_rules": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              }
            },
            "additionalProperties": false
          }
        },
        "interaction_ritual": {
          "type": "object",
          "required": ["loop", "input_channels", "state_machine"],
          "properties": {
            "loop": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "input_channels": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["channel_id", "semantic_role", "input_modes", "uses"],
                "properties": {
                  "channel_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
                  "semantic_role": { "type": "string", "minLength": 1 },
                  "input_modes": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "uses": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  }
                },
                "additionalProperties": false
              }
            },
            "state_machine": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["state_id", "purpose"],
                "properties": {
                  "state_id": { "type": "string", "pattern": "^[A-Z][A-Za-z]+$" },
                  "purpose": { "type": "string", "minLength": 1 }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "scene_state_contract": {
          "type": "object",
          "required": ["required_fields", "state_guarantees"],
          "properties": {
            "required_fields": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "state_guarantees": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "additionalProperties": false
        },
        "interaction_event_model": {
          "type": "object",
          "required": ["event_types", "dispatch_rules"],
          "properties": {
            "event_types": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
            },
            "dispatch_rules": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "additionalProperties": false
        },
        "visual_modulation_contract": {
          "type": "object",
          "required": ["required_fields", "rendering_layers", "form_strategy", "supporting_strategies"],
          "properties": {
            "required_fields": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "rendering_layers": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "form_strategy": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "supporting_strategies": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "additionalProperties": false
        },
        "test_scenarios": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "checks"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
              "checks": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "slo_notes": {
      "type": "object",
      "required": ["common_kpi_set", "critical_metrics", "error_budget"],
      "properties": {
        "common_kpi_set": { "type": "string", "minLength": 1 },
        "critical_metrics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "target", "alert", "window", "notes"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "target": { "type": "string", "minLength": 1 },
              "alert": { "type": "string", "minLength": 1 },
              "window": { "type": "string", "minLength": 1 },
              "notes": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "error_budget": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "change_log": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["release_line", "change", "date_label"],
        "properties": {
          "release_line": { "type": "string", "minLength": 1 },
          "change": { "type": "string", "minLength": 1 },
          "date_label": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
