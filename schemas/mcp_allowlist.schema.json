{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ServiceMcpAllowlist",
  "type": "object",
  "required": ["service_id", "allowed_mcps"],
  "properties": {
    "service_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "allowed_mcps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["mcp_id", "capabilities"],
        "properties": {
          "mcp_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "capabilities": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
