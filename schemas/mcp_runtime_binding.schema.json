{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "McpRuntimeBinding",
  "type": "object",
  "required": [
    "version",
    "runtime_owner_service",
    "runtime_repo_path",
    "invocation_surface",
    "sdk_package",
    "validation_package",
    "tool_names"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v0.1"
    },
    "runtime_owner_service": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "runtime_repo_path": {
      "type": "string",
      "minLength": 1
    },
    "invocation_surface": {
      "type": "string",
      "minLength": 1
    },
    "sdk_package": {
      "type": "string",
      "minLength": 1
    },
    "validation_package": {
      "type": "string",
      "minLength": 1
    },
    "tool_names": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9._-]*$"
      }
    }
  },
  "additionalProperties": false
}
