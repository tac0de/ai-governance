{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PromptsRegistry",
  "type": "object",
  "required": ["version", "prompts"],
  "properties": {
    "version": { "type": "string", "const": "v0.1" },
    "prompts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "root_path", "pack_ref", "pinned_ref_hash"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "name": { "type": "string", "minLength": 1 },
          "root_path": {
            "type": "string",
            "pattern": "^prompts/packs/[a-z0-9][a-z0-9-]*$"
          },
          "pack_ref": {
            "type": "string",
            "pattern": "^prompts/packs/[a-z0-9][a-z0-9-]*/pack\\.v0\\.1\\.json$"
          },
          "pinned_ref_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

