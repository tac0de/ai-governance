{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentsRegistry",
  "type": "object",
  "required": ["version", "agents"],
  "properties": {
    "version": { "type": "string", "const": "v0.1" },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "provider",
          "root_path",
          "profile_ref",
          "default_prompt_pack_id",
          "risk_level",
          "pinned_ref_hash"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "name": { "type": "string", "minLength": 1 },
          "provider": {
            "type": "string",
            "enum": ["openai", "google", "anthropic", "other"]
          },
          "root_path": {
            "type": "string",
            "pattern": "^agents/models/[a-z0-9][a-z0-9-]*$"
          },
          "profile_ref": {
            "type": "string",
            "pattern": "^agents/models/[a-z0-9][a-z0-9-]*/agent\\.profile\\.v0\\.1\\.json$"
          },
          "default_prompt_pack_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "risk_level": { "type": "string", "enum": ["low", "medium", "high"] },
          "pinned_ref_hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

