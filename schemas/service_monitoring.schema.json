{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ServiceMonitoringPolicy",
  "type": "object",
  "required": [
    "version",
    "model",
    "purpose",
    "applies_to",
    "required_artifacts",
    "monitoring_status_levels",
    "trigger_conditions",
    "hard_rules"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v0.7"
    },
    "model": {
      "type": "string",
      "const": "continuous-service-monitoring"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "applies_to": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._/-]+$"
      }
    },
    "monitoring_status_levels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "pending",
          "active",
          "attention",
          "cleanup-required"
        ]
      }
    },
    "trigger_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "hard_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
