{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ServiceAgentProposal",
  "type": "object",
  "required": [
    "version",
    "service_id",
    "role_id",
    "proposal_id",
    "output_kind",
    "state_refs",
    "intent_ref",
    "policy_refs",
    "evidence_refs",
    "change_summary",
    "acceptance_checks"
  ],
  "properties": {
    "version": { "type": "string", "const": "v0.1" },
    "service_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "role_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "proposal_id": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$" },
    "output_kind": { "type": "string", "minLength": 1 },
    "state_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "intent_ref": { "type": "string", "minLength": 1 },
    "trace_ref": { "type": ["string", "null"], "minLength": 1 },
    "policy_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "change_summary": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "acceptance_checks": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
