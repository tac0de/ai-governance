{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentRoutingPolicy",
  "type": "object",
  "required": ["version", "allowed_executors_by_tier", "fallback_chain"],
  "properties": {
    "version": { "type": "string", "const": "v0.1" },
    "allowed_executors_by_tier": {
      "type": "object",
      "required": ["low", "medium", "high"],
      "properties": {
        "low": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "uniqueItems": true
        },
        "medium": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "uniqueItems": true
        },
        "high": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "fallback_chain": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}

