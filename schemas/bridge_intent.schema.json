{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BridgeIntent",
  "type": "object",
  "required": [
    "intent_id",
    "objective",
    "constraints",
    "approval_tier",
    "human_gate_required",
    "target_executor",
    "evidence_refs"
  ],
  "properties": {
    "intent_id": { "type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._-]*$" },
    "objective": { "type": "string", "minLength": 1 },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "approval_tier": { "type": "string", "enum": ["low", "medium", "high"] },
    "human_gate_required": { "type": "boolean" },
    "target_executor": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "prompt_pack_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
