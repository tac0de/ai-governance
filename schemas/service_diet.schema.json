{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ServiceDietPolicy",
  "type": "object",
  "required": [
    "version",
    "model",
    "purpose",
    "scan_axes",
    "required_outputs",
    "cleanup_modes",
    "status_levels",
    "archive_policy",
    "auto_fix_scope",
    "classification_rules",
    "completion_rule",
    "hard_rules"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v0.7"
    },
    "model": {
      "type": "string",
      "const": "linked-service-diet"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "scan_axes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "axis_id",
          "question"
        ],
        "properties": {
          "axis_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "question": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "required_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9_-]*$"
      }
    },
    "cleanup_modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "status_levels": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": [
          "status",
          "meaning"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "diet-scanned-light",
              "diet-scanned-deep",
              "cleanup-required",
              "incomplete"
            ]
          },
          "meaning": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "archive_policy": {
      "type": "object",
      "required": [
        "allowed_actions",
        "forbidden_actions"
      ],
      "properties": {
        "allowed_actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        },
        "forbidden_actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        }
      },
      "additionalProperties": false
    },
    "auto_fix_scope": {
      "type": "object",
      "required": [
        "auto_create_missing_required_paths",
        "auto_write_missing_monitoring_artifacts",
        "auto_move_archive_candidates",
        "auto_delete_review_candidates"
      ],
      "properties": {
        "auto_create_missing_required_paths": {
          "type": "boolean"
        },
        "auto_write_missing_monitoring_artifacts": {
          "type": "boolean"
        },
        "auto_move_archive_candidates": {
          "type": "boolean"
        },
        "auto_delete_review_candidates": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "classification_rules": {
      "type": "object",
      "required": [
        "retain_if_any",
        "archive_if_all",
        "forbidden_if_any"
      ],
      "properties": {
        "retain_if_any": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        },
        "archive_if_all": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        },
        "forbidden_if_any": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        }
      },
      "additionalProperties": false
    },
    "completion_rule": {
      "type": "object",
      "required": [
        "required_status",
        "linked_service_fields"
      ],
      "properties": {
        "required_status": {
          "type": "string",
          "const": "diet-scanned-light"
        },
        "linked_service_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          }
        }
      },
      "additionalProperties": false
    },
    "hard_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
