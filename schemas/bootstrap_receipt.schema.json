{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BootstrapReceipt",
  "type": "object",
  "required": [
    "version",
    "service_id",
    "source_release_line",
    "bootstrap_manifest_ref",
    "generated_artifacts",
    "export_mode",
    "git_initialized",
    "seed_profile",
    "notes"
  ],
  "properties": {
    "version": { "type": "string", "const": "v0.1" },
    "service_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "source_release_line": { "type": "string", "minLength": 1 },
    "bootstrap_manifest_ref": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "generated_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256", "kind"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "kind": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "export_mode": { "type": "string", "enum": ["folder-repo-init"] },
    "git_initialized": { "type": "boolean" },
    "seed_profile": { "type": "string", "enum": ["standard", "ritual-uiux"] },
    "notes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
