{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ControlPlaybook",
  "type": "object",
  "required": [
    "version",
    "playbook_id",
    "title",
    "objective",
    "trigger_conditions",
    "required_inputs",
    "execution_steps",
    "rollback_condition",
    "evidence_outputs"
  ],
  "properties": {
    "version": { "type": "string", "const": "v0.1" },
    "playbook_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "title": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "trigger_conditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_inputs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "execution_steps": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "rollback_condition": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_outputs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
