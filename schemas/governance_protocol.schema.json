{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GovernanceProtocol",
  "type": "object",
  "required": [
    "version",
    "model",
    "purpose",
    "stages",
    "invariants"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v0.7"
    },
    "model": {
      "type": "string",
      "const": "governance-protocol"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "stages": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "required": [
          "stage_id",
          "required_ref",
          "produces",
          "consumes",
          "gate_rule"
        ],
        "properties": {
          "stage_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_]*$"
          },
          "required_ref": {
            "type": "string",
            "minLength": 1
          },
          "produces": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "consumes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "gate_rule": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "invariants": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
