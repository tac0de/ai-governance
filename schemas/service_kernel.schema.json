{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ServiceKernel",
  "type": "object",
  "required": [
    "version",
    "model",
    "purpose",
    "required_root_entries",
    "required_governance_entries",
    "required_orchestration_entries",
    "required_prompt_entries",
    "optional_root_entries",
    "profiles",
    "rules"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v0.7"
    },
    "model": {
      "type": "string",
      "const": "linked-service-kernel"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "required_root_entries": {
      "type": "array",
      "minItems": 6,
      "items": {
        "$ref": "#/$defs/entry"
      }
    },
    "required_governance_entries": {
      "type": "array",
      "minItems": 11,
      "items": {
        "$ref": "#/$defs/entry"
      }
    },
    "required_orchestration_entries": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/entry"
      }
    },
    "required_prompt_entries": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/entry"
      }
    },
    "optional_root_entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._/-]+$"
      }
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "profile_id",
          "recommended_entries",
          "notes"
        ],
        "properties": {
          "profile_id": {
            "type": "string",
            "enum": [
              "web-runtime",
              "tool-runtime",
              "worker-runtime"
            ]
          },
          "recommended_entries": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9._/-]+$"
            }
          },
          "notes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "required": [
        "path",
        "entry_type"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._/-]+$"
        },
        "entry_type": {
          "type": "string",
          "enum": [
            "file",
            "directory"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
