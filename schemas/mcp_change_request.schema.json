{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "McpChangeRequest",
  "type": "object",
  "required": [
    "version",
    "request_id",
    "service_id",
    "requested_at",
    "status"
  ],
  "properties": {
    "version": { "type": "string", "const": "v0.1" },
    "request_id": { "type": "string", "minLength": 1 },
    "service_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "requested_at": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["proposed", "requested", "approved", "rejected", "implemented", "deferred"]
    },
    "request_type": {
      "type": "string",
      "enum": ["capability_expansion", "new_mcp_registration"]
    },
    "approval_tier": { "type": "string", "enum": ["low", "medium", "high"] },
    "risk_tier": { "type": "string", "enum": ["low", "medium", "high"] },
    "human_gate_required": { "type": "boolean" },
    "title": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "required_capabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "target_core_mcp_id": { "type": "string", "pattern": "^core-[a-z0-9][a-z0-9-]*$" },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "io_contract": { "type": "object" },
    "mcp_candidate": {
      "type": "object",
      "required": [
        "id",
        "name",
        "proposed_root_path",
        "capabilities",
        "required_approval_tier",
        "risk_level"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^core-[a-z0-9][a-z0-9-]*$" },
        "name": { "type": "string", "minLength": 1 },
        "proposed_root_path": { "type": "string", "pattern": "^control/mcps/core-[a-z0-9][a-z0-9-]*$" },
        "capabilities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "required_approval_tier": { "type": "string", "enum": ["low", "medium", "high"] },
        "risk_level": { "type": "string", "enum": ["low", "medium", "high"] }
      },
      "additionalProperties": false
    },
    "governance_rationale": {
      "type": "object",
      "required": ["need", "boundary", "controls"],
      "properties": {
        "need": { "type": "string", "minLength": 1 },
        "boundary": { "type": "string", "minLength": 1 },
        "controls": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "expected_artifacts": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    }
  },
  "oneOf": [
    {
      "required": [
        "approval_tier",
        "human_gate_required",
        "title",
        "objective",
        "required_capabilities",
        "constraints",
        "evidence_refs"
      ]
    },
    {
      "required": [
        "request_type",
        "approval_tier",
        "human_gate_required",
        "mcp_candidate",
        "governance_rationale",
        "expected_artifacts"
      ],
      "properties": {
        "request_type": { "const": "new_mcp_registration" }
      }
    }
  ],
  "additionalProperties": false
}
