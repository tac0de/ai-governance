{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LinkAuthContract",
  "type": "object",
  "required": [
    "version",
    "model",
    "purpose",
    "required_fields",
    "status_values",
    "scope_catalog",
    "hard_rules"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v0.7"
    },
    "model": {
      "type": "string",
      "const": "link-auth-contract"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "required_fields": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9_]*$"
      }
    },
    "status_values": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "enum": [
          "active",
          "revoked",
          "expired"
        ]
      }
    },
    "scope_catalog": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "hard_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
