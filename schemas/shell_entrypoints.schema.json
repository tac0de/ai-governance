{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ShellEntrypoints",
  "type": "object",
  "required": [
    "version",
    "model",
    "purpose",
    "commands"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "v0.7"
    },
    "model": {
      "type": "string",
      "const": "shell-entrypoints"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "commands": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": [
          "command_id",
          "entry_path",
          "required_inputs",
          "produces",
          "guardrails"
        ],
        "properties": {
          "command_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "entry_path": {
            "type": "string",
            "minLength": 1
          },
          "required_inputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "produces": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "guardrails": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
