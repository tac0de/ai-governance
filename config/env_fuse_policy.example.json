{
  "version": "1.0.0",
  "defaults": {
    "dry_run": true,
    "real_apply_requires_human_gate": true
  },
  "budget": {
    "monthly_usd_cap": 500,
    "per_service_usd_cap": 100
  },
  "model_policy": {
    "allowlist": ["gpt-5-nano", "gpt-5-mini", "gpt-5"],
    "max_output_tokens": 1200
  },
  "risk_gate": {
    "high_risk_requires_approval": true,
    "contract_breaking_change_requires_approval": true
  },
  "audit": {
    "required_fields": [
      "timestamp",
      "actor",
      "reason",
      "diff_summary",
      "rollback_ref"
    ],
    "append_only": true
  }
}
