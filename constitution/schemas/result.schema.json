{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-governance/constitution/schemas/result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "request_id", "actions"],
  "properties": {
    "version": { "const": "1.0" },
    "request_id": { "type": "string", "format": "uuid" },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "artifacts", "stdout_summary", "stderr_summary"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["ok", "error"] },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "sha256"],
              "properties": {
                "path": { "type": "string", "minLength": 1 },
                "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
              }
            }
          },
          "stdout_summary": { "type": "string" },
          "stderr_summary": { "type": "string" }
        }
      }
    }
  }
}
